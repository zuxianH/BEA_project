Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ModestoRiggedConfig", "[", 
    RowBox[{"L_", ",", "modes_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Mmatrix", ",", "limits", ",", "deleteFirstLastLine"}], "}"}], ",",
      "\n", 
     RowBox[{
      RowBox[{"Mmatrix", "=", 
       RowBox[{"PadRight", "[", 
        RowBox[{"Append", "[", 
         RowBox[{
          RowBox[{"Prepend", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Length", "[", 
               RowBox[{"modes", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", 
                RowBox[{"Length", "[", 
                 RowBox[{"modes", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"SparseArray", "[", 
             RowBox[{
              RowBox[{"1", "->", "L"}], ",", "1"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", "0", "}"}]}], "]"}], "]"}]}], ";", "\n", "\n", 
      RowBox[{
       RowBox[{"deleteFirstLastLine", "[", "x_", "]"}], ":=", 
       RowBox[{"Delete", "[", 
        RowBox[{"x", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"limits", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", 
         RowBox[{"deleteFirstLastLine", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"Cartan", "[", 
               RowBox[{"Length", "[", "Mmatrix", "]"}], "]"}], " ", ".", " ", 
              "Mmatrix", " ", ".", " ", 
              RowBox[{"Kernel", "[", 
               RowBox[{"Length", "[", 
                RowBox[{"Mmatrix", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}]}], "+", 
            "Mmatrix"}], "/.", 
           RowBox[{"{", 
            RowBox[{"0", "->", 
             RowBox[{"{", "}"}]}], "}"}]}], "]"}]}], "-", 
        RowBox[{"1", "/", "2"}]}]}], ";", "\n", "\n", 
      RowBox[{"Prepend", "[", "\n", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{"Append", "[", 
          RowBox[{"{", "}"}], "]"}], "/@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"i", ",", 
                    RowBox[{"Length", "[", 
                    RowBox[{"modes", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}], "]"}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", 
                    RowBox[{"Sort", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"Length", "[", 
                    RowBox[{"modes", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "]"}], "]"}], ",", 
                    "Greater"}], "]"}]}], "}"}]}], "]"}], "//", "Catenate"}], 
               ",", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"limits", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}], "+", 
                   RowBox[{"modes", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i", ",", "k"}], "]"}], "]"}], "+", "1",
                    "-", "k"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", 
                    RowBox[{"Sort", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", 
                    RowBox[{"Length", "[", 
                    RowBox[{"modes", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "]"}], "]"}], ",", 
                    "Greater"}], "]"}]}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"k", ",", 
                    RowBox[{"Length", "[", 
                    RowBox[{"modes", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}], "]"}]}], "}"}]}], 
                 "]"}], "//", "Catenate"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", 
               RowBox[{"Length", "[", "modes", "]"}]}], "}"}]}], "]"}], "//", 
           "Transpose"}], ")"}]}], "\n", "\n", "\n", ",", 
        RowBox[{"{", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"1", ",", "L"}], "]"}], "}"}]}], "]"}]}]}], "\n", "\n", 
    "]"}]}], "\n", "\n", "\n"}]], "Code",
 CellLabel->"In[18]:=",ExpressionUUID->"a6201967-6bdc-44f9-83af-82c829296eac"]
