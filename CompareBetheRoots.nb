Cell[CellGroupData[{

Cell["Nearest (Euclidean distance)", "Subsection",
 CellChangeTimes->{{3.9591018026950607`*^9, 
  3.959101811378908*^9}},ExpressionUUID->"fa3f82ce-a22e-404c-8029-\
90ac76c0bd29"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"makeNearestTable", "[", 
    RowBox[{"yd_", ",", " ", "distFunc_", ",", "range_"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{"ParallelTable", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"loaddata", "[", 
       RowBox[{"yd", ",", " ", "w"}], "]"}], ";", "\n", "  ", 
      RowBox[{"Nearestdata", " ", "=", " ", 
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Table", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"{", "\n", "        ", 
            RowBox[{
             RowBox[{
              RowBox[{"lazyroots", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "[", 
              RowBox[{"[", "kk", "]"}], "]"}], ",", "\n", "        ", 
             RowBox[{"First", " ", "@", " ", 
              RowBox[{"Nearest", "[", 
               RowBox[{
                RowBox[{"stringroots", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", " ", 
                RowBox[{
                 RowBox[{"lazyroots", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "[", 
                 RowBox[{"[", "kk", "]"}], "]"}]}], "]"}]}]}], "\n", "      ",
             "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{"kk", ",", " ", 
             RowBox[{"Length", "[", 
              RowBox[{"lazyroots", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "\n", "    ",
           "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", 
           RowBox[{"Length", "[", "lazyroots", "]"}]}], "}"}]}], "\n", "  ", 
        "]"}]}], ";", "\n", "  ", 
      RowBox[{"{", "\n", "    ", 
       RowBox[{"w", ",", "\n", "    ", 
        RowBox[{"Mean", " ", "@", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"distFunc", " ", "@@", " ", "#"}], " ", "&"}], " ", "/@", 
           " ", 
           RowBox[{"(", 
            RowBox[{"ReIm", " ", "/@", " ", 
             RowBox[{"Flatten", "[", 
              RowBox[{"Nearestdata", ",", " ", "1"}], "]"}]}], ")"}]}], 
          ")"}]}]}], "\n", "  ", "}"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"w", ",", " ", "1", ",", " ", "range", ",", " ", "1"}], "}"}]}],
     "\n", "]"}]}], "\n"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.959101914925516*^9, 3.959101914925544*^9}, {
  3.9591020071263866`*^9, 3.959102039144134*^9}},
