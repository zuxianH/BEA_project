  RowBox[{"(*", 
   RowBox[{
   "Code", " ", "finding", " ", "all", " ", "rigged", " ", "configurations", " ",
     "for", " ", "a", " ", "given", " ", "Young", " ", "diagramme"}], "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{"ModesConfig", "[", "yd_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"Modes", "=", 
       RowBox[{
        RowBox[{"AdmissibleModes", "[", "yd", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
      RowBox[{"Mmatrices", "=", 
       RowBox[{
        RowBox[{"AdmissibleModes", "[", "yd", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"Table", "[", "\n", 
        RowBox[{
         RowBox[{"Tuples", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Tuples", "[", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Subsets", "[", 
                RowBox[{
                 RowBox[{"Range", "[", 
                  RowBox[{
                   RowBox[{"-", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Modes", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}], ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Modes", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"Mmatrices", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "//", "Total"}], "}"}]}], 
                "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", 
                 RowBox[{"Length", "[", 
                  RowBox[{
                   RowBox[{"Modes", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
             "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", 
              RowBox[{"Length", "[", 
               RowBox[{"Modes", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "Modes", "]"}]}], "}"}]}], "]"}], "//", 
       "Catenate"}]}]}], "]"}]}]}]], "Code",
