  RowBox[{"(*", 
   RowBox[{
   "Filling", " ", "the", " ", "Young", " ", "diagram", " ", "with", " ", 
    "M_as", " ", "values"}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Msetmatrix", "[", "yd_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Ms", ",", "Mmatrices", ",", "UpdMmatrices", ",", "M"}], "}"}], 
     ",", "\n", 
     RowBox[{
      RowBox[{"Ms", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"First", "/@", 
          RowBox[{"AugmentedYoungD", "[", "yd", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"Mmatrices", "=", 
       RowBox[{"PadRight", "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{"Replace", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"x__", ",", 
                RowBox[{"0", ".."}]}], "}"}], "->", 
              RowBox[{"{", "x", "}"}]}], "]"}], ",", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Solve", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Sum", "[", 
                   RowBox[{
                    RowBox[{"s", "*", 
                    RowBox[{"M", "[", "s", "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"s", ",", "1", ",", "\[Lambda]"}], "}"}]}], "]"}],
                   "==", "\[Lambda]"}], ",", 
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"M", "[", "t", "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"t", ",", "1", ",", "\[Lambda]"}], "}"}]}], "]"}],
                  ",", "NonNegativeIntegers"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"\[Lambda]", ",", "Ms"}], "}"}]}], "]"}], "//", 
             "Values"}], " ", ",", 
            RowBox[{"{", "2", "}"}]}], "]"}], "//", "Tuples"}], ")"}]}]}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"All", " ", "possible", " ", "Ms", " ", "sets"}], ";", 
        RowBox[{
        "the", " ", "index", " ", "is", " ", "the", " ", "string", " ", 
         "length", " ", "and", " ", "the", " ", "value", " ", "is", " ", 
         "the", " ", "number", " ", "of", " ", "strings", " ", "of", " ", 
         "that", " ", "length"}]}], "*)"}], ";", "\n", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
