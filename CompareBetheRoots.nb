     "set"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AdmissibleModes", "[", "yd_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "Mmatrices", "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"Mmatrices", "=", 
