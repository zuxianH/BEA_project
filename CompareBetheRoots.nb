  3.959136267279649*^9},ExpressionUUID->"4e3c3d04-2a7a-4df4-a1f4-\
6f14789a9d18"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"makeClusterTable", "[", 
    RowBox[{"yd_", ",", "range_"}], "]"}], " ", ":=", " ", 
   RowBox[{"ParallelTable", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"loaddata", "[", 
       RowBox[{"yd", ",", " ", "rigg"}], "]"}], ";", "\n", "  ", "\n", "  ", 
      RowBox[{"clusterdata", " ", "=", " ", 
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"FindClusters", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"ReIm", " ", "/@", " ", 
              RowBox[{"lazyroots", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], ",", " ", 
             RowBox[{"ReIm", " ", "/@", " ", 
              RowBox[{"stringroots", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}]}], "]"}], ",", "\n", "      ", 
           RowBox[{"Length", "[", 
            RowBox[{"lazyroots", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "]"}], ",", "\n", "      ", 
           RowBox[{"Method", " ", "->", " ", "\"\<Agglomerate\>\""}]}], "\n", 
          "    ", "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", 
           RowBox[{"Length", "[", "lazyroots", "]"}]}], "}"}]}], "\n", "  ", 
        "]"}]}], ";", "\n", "  ", "\n", "  ", 
      RowBox[{"Countclusterdata", " ", "=", " ", 
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Length", " ", "/@", " ", 
          RowBox[{"clusterdata", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", 
           RowBox[{"Length", "[", "lazyroots", "]"}]}], "}"}]}], "\n", "  ", 
        "]"}]}], ";", "\n", "  ", "\n", "  ", 
      RowBox[{"MeanCountclusterdata", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Countclusterdata", " ", "//", " ", "Flatten"}], " ", "//", 
         " ", "Min"}], " ", "//", " ", "N"}]}], ";", "\n", "  ", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{
       "rigg", ",", " ", "MeanCountclusterdata", ",", " ", 
        "Countclusterdata"}], "}"}]}], ",", "\n", "  ", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"rigg", ",", " ", "1", ",", " ", "range", ",", " ", "1"}], 
      "}"}]}], "\n", "]"}]}], "\n"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.959102644533297*^9, 3.9591026575558777`*^9}, {
  3.959103342313478*^9, 3.959103342860882*^9}, {3.959103399050585*^9, 
