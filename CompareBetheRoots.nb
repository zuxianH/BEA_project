     RowBox[{
      RowBox[{"Min", "[", 
       RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "s"}], "}"}]}], "]"}]}], "\n", "\n", 
  RowBox[{"(*", 
