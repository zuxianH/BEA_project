                 RowBox[{"Length", "[", 
                  RowBox[{"UpdMmatrices", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], "]"}], ",", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"Length", "[", 
                RowBox[{"UpdMmatrices", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], "]"}]}]}], 
         "]"}], "\n", "\n", ",", 
        RowBox[{"{", 
         RowBox[{"matrix", ",", "Mmatrices"}], "}"}]}], "]"}]}]}], "\n", 
    "]"}]}], "\n", "\n", 
  RowBox[{"(*", 
