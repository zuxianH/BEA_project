 RowBox[{
  RowBox[{
   RowBox[{"TransposeYoungD", "[", "shape_", "]"}], " ", ":=", " ", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"Select", "[", 
