    "\n", " ", 
   RowBox[{
    RowBox[{"Total", "[", "shape", "]"}], " ", "-", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"shape", "[", 
       RowBox[{"[", "b", "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"b", ",", " ", "1", ",", " ", "a"}], "}"}]}], "]"}], " ", "-", 
    " ", "\n", "  ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"TransposeYoungD", "[", "shape", "]"}], "[", 
