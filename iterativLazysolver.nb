Cell[CellGroupData[{

Cell["Numerical iterations", "Subsection",
 CellChangeTimes->{{3.782994687726842*^9, 3.782994691345057*^9}, {
  3.789669089521549*^9, 3.7896691068603697`*^9}, {3.789752026307534*^9, 
