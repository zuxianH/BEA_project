     ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Clear", " ", "previous", " ", "print", " ", "outputs"}], " ", 
      "*)"}], "\n", "\n", "  ", "\n", "  ", 
     RowBox[{"duplicateRootPositions", " ", "=", " ", 
      RowBox[{
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}], "//",
        "Flatten"}]}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Original dubbel\>\"", " ", ",", 
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}]}],
       "]"}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"previousDuplicateRootPositions", " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Start", " ", "with", " ", "an", " ", "empty", " ", "comparison", " ", 
       "list"}], " ", "*)"}], "\n", "\n", " ", "\n", "  ", 
     RowBox[{"iterationstep", " ", "=", " ", "7"}], ";", "\n", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Iterate", " ", "until", " ", "there", " ", "are", " ", "no", " ", 
       "duplicate", " ", "root", " ", "positions"}], " ", "*)"}], "\n", "  ", 
     
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"duplicateRootPositions", " ", "=!=", " ", 
        RowBox[{"{", "}"}]}], ",", "\n", "   ", "\n", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Find", " ", "positions", " ", "that", " ", "changed", " ", "from", 
         " ", "the", " ", "last", " ", "iteration"}], " ", "*)"}], "\n", 
       "    ", 
       RowBox[{
        RowBox[{"changedPositions", " ", "=", " ", 
         RowBox[{"Complement", "[", 
          RowBox[{
          "duplicateRootPositions", ",", " ", 
           "previousDuplicateRootPositions"}], "]"}]}], ";", "\n", "\n", 
        "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Update", " ", "only", " ", "if", " ", "any", " ", "positions", " ", 
          "have", " ", "changed"}], " ", "*)"}], "\n", "    ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"changedPositions", " ", "=!=", " ", 
           RowBox[{"{", "}"}]}], ",", "\n", "     ", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{"changeHistory", ",", "changedPositions"}], "]"}], ";", 
           "\n", "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Perform", " ", "iteration", " ", "step", " ", "with", " ", 
             "increasing", " ", "parameter"}], " ", "*)"}], "\n", "      ", 
           RowBox[{"NewStepIterate", "[", 
            RowBox[{"0.3", ",", " ", "iterationstep"}], "]"}], ";", "\n", 
           "      ", 
           RowBox[{"iterationstep", "++"}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{"Increment", " ", "iteration", " ", "step"}], " ", "*)"}],
            "\n", "\n", "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Solve", " ", "again", " ", "only", " ", "for", " ", "the", " ", 
             "changed", " ", "duplicate", " ", "positions"}], " ", "*)"}], 
           "\n", "      ", 
           RowBox[{"newsolutions", " ", "=", " ", 
            RowBox[{"ParallelTable", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"lazySolver", "[", 
               RowBox[{"yd", ",", " ", 
                RowBox[{"duplicateRootPositions", "[", 
