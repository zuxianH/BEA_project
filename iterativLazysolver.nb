           RowBox[{"mysol", " ", "=", " ", "\n", "    ", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"YQa", "[", 
                RowBox[{"a", ",", " ", "0"}], "]"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"a", ",", " ", 
                 RowBox[{"Length", "[", 
                  RowBox[{"\[Lambda]", " ", "-", " ", "1"}], "]"}]}], "}"}]}],
               "]"}], " ", "/.", " ", "\n", "     ", 
             RowBox[{"First", "[", 
              RowBox[{
               RowBox[{"vars2nvars", " ", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{"FindSol", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "}"}]}], " ", "/.", " ", 
               RowBox[{"\[CapitalLambda]", " ", "->", " ", "1"}]}], "]"}]}]}],
            ";", "\n", "   ", "\n", "   ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"allbetheQ", ",", " ", "mysol"}], "]"}], ";", "\n", "   ",
            "\n", "   ", 
           RowBox[{"allbetherootEqns", " ", "=", " ", 
            RowBox[{
             RowBox[{"Map", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"#", " ", "==", " ", "0"}], " ", "&"}], ",", " ", 
               "allbetheQ", ",", " ", 
               RowBox[{"{", "2", "}"}]}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", " ", 
               RowBox[{"1", " ", ";;", " ", "2"}]}], "]"}], "]"}]}], ";", 
           "\n", "   ", 
           RowBox[{"solvedBetheroots", " ", "=", "\n", "    ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Table", "[", "\n", "        ", 
                RowBox[{
                 RowBox[{"Table", "[", "\n", "         ", 
                  RowBox[{
                   RowBox[{"Solve", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"allbetherootEqns", "[", 
                    RowBox[{"[", "w", "]"}], "]"}], "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", " ", "u"}], "]"}], 
                   ",", "\n", "         ", 
                   RowBox[{"{", 
                    RowBox[{"k", ",", " ", 
                    RowBox[{"Length", "[", 
                    RowBox[{"allbetherootEqns", "[", 
                    RowBox[{"[", "w", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
                 ",", "\n", "        ", 
                 RowBox[{"{", 
                  RowBox[{"w", ",", " ", 
                   RowBox[{"Length", "[", "allbetherootEqns", "]"}]}], 
                  "}"}]}], "]"}], " ", "//", " ", "Values"}], ")"}], " ", "-",
              " ", "1"}]}], ";", "\n", "   ", "\n", "   ", 
           RowBox[{"listCcoefficient", " ", "=", " ", "\n", "    ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"vars2nvars", " ", "/.", " ", 
                RowBox[{"\[CapitalLambda]", " ", "->", " ", 
                 RowBox[{"\[CapitalLambda]vals", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}]}], " ", "/.", " ", "\n", 
               "      ", 
               RowBox[{"sol", "[", 
                RowBox[{"\[CapitalLambda]vals", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "]"}]}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"k", ",", " ", "\n", "      ", 
                RowBox[{"Length", "[", "\[CapitalLambda]vals", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\n", "   ", "\n", "   ", 
           RowBox[{"listUmonomial", " ", "=", " ", "\n", "    ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"k", ",", " ", 
                RowBox[{"\[CapitalLambda]vals", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", " ", "\n", "      ", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"YQa", "[", 
                   RowBox[{"a", ",", " ", "0"}], "]"}], ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"a", ",", " ", 
                    RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], " ", "-", " ", 
                    "1"}]}], "}"}]}], "]"}]}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"k", ",", " ", "\n", "      ", 
                RowBox[{"Length", "[", "\[CapitalLambda]vals", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\n", "   ", "\n", "   ", 
           RowBox[{"listUmonomialValue", " ", "=", " ", "\n", "    ", 
            RowBox[{"MapThread", "[", "\n", "     ", 
             RowBox[{"ReplaceAll", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"listUmonomial", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", " ", "3"}], "]"}], "]"}], ",", " ", 
                "listCcoefficient"}], "}"}]}], "]"}]}], ";", "\n", "   ", 
           "\n", "   ", 
           RowBox[{"listUmonomialCoffValue", " ", "=", " ", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{"listUmonomialValue", ",", " ", "u"}], "]"}]}], ";", 
           "\n", "   ", "\n", "   ", 
           RowBox[{"{", 
            RowBox[{
            "solvedBetheroots", ",", " ", "listUmonomialCoffValue", ",", " ", 
             "\[CapitalLambda]vals"}], "}"}]}]}], "\n", "   ", "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "]"}]}]], "Input",
