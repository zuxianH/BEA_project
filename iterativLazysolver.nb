        "}"}]}], "]"}]}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DualDiagram", "[", "\[Lambda]_", "]"}], " ", ":=", " ", 
