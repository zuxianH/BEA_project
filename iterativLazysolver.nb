          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
        RowBox[{"10", "^", 
         RowBox[{"-", "5"}]}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Round", " ", "Bethe", " ", "roots", " ", "to", " ", "5", " ", 
       "decimal", " ", "places"}], " ", "*)"}], "\n", 
     RowBox[{"tallyBetheRoots", " ", "=", " ", 
