Cell[BoxData[{
 RowBox[{
  RowBox[{"changeHistory", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"newlazysolver", "[", "yd_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "solvedBetheroots", ",", " ", "duplicateRootPositions", ",", " ", "\n", 
      "   ", "previousDuplicateRootPositions", ",", " ", "iterationstep", ",",
       " ", "newsolutions", ",", " ", "changedPositions"}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{
     RowBox[{"OldStepIterate", "[", "]"}], ";", "\n", "  ", 
     RowBox[{"solvedBetheroots", " ", "=", " ", 
      RowBox[{"ParallelTable", "[", 
       RowBox[{
        RowBox[{"lazySolver", "[", 
         RowBox[{"yd", ",", " ", "rigg", ",", "50", ",", "4"}], "]"}], ",", 
        " ", 
        RowBox[{"{", 
         RowBox[{"rigg", ",", " ", 
          RowBox[{"Length", "[", "rigs", "]"}]}], "}"}]}], "]"}]}], ";", "\n",
      "  ", 
     RowBox[{"NotebookDelete", "[", 
      RowBox[{"Cells", "[", 
       RowBox[{"CellStyle", " ", "->", " ", "\"\<Print\>\""}], "]"}], "]"}], 
     ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Clear", " ", "previous", " ", "print", " ", "outputs"}], " ", 
      "*)"}], "\n", "\n", "  ", "\n", "  ", 
     RowBox[{"duplicateRootPositions", " ", "=", " ", 
      RowBox[{
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}], "//",
        "Flatten"}]}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Original dubbel\>\"", " ", ",", 
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}]}],
       "]"}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"previousDuplicateRootPositions", " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Start", " ", "with", " ", "an", " ", "empty", " ", "comparison", " ", 
       "list"}], " ", "*)"}], "\n", "\n", " ", "\n", "  ", 
     RowBox[{"iterationstep", " ", "=", " ", "7"}], ";", "\n", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Iterate", " ", "until", " ", "there", " ", "are", " ", "no", " ", 
       "duplicate", " ", "root", " ", "positions"}], " ", "*)"}], "\n", "  ", 
     
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "duplicateRootPositions", "]"}], "!=", "0"}], 
       ",", "\n", "   ", "\n", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Find", " ", "positions", " ", "that", " ", "changed", " ", "from", 
         " ", "the", " ", "last", " ", "iteration"}], " ", "*)"}], "\n", 
       "    ", 
       RowBox[{
        RowBox[{"changedPositions", " ", "=", " ", 
         RowBox[{"Complement", "[", 
          RowBox[{
          "duplicateRootPositions", ",", " ", 
           "previousDuplicateRootPositions"}], "]"}]}], ";", "\n", "\n", 
        "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Update", " ", "only", " ", "if", " ", "any", " ", "positions", " ", 
          "have", " ", "changed"}], " ", "*)"}], "\n", "    ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"changedPositions", " ", "=!=", " ", 
           RowBox[{"{", "}"}]}], ",", "\n", "     ", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{"changeHistory", ",", "changedPositions"}], "]"}], ";", 
           "\n", "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Perform", " ", "iteration", " ", "step", " ", "with", " ", 
             "increasing", " ", "parameter"}], " ", "*)"}], "\n", "      ", 
           RowBox[{"NewStepIterate", "[", 
            RowBox[{"0.3", ",", " ", "iterationstep"}], "]"}], ";", "\n", 
           "      ", 
           RowBox[{"iterationstep", "++"}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{"Increment", " ", "iteration", " ", "step"}], " ", "*)"}],
            "\n", "\n", "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Solve", " ", "again", " ", "only", " ", "for", " ", "the", " ", 
             "changed", " ", "duplicate", " ", "positions"}], " ", "*)"}], 
           "\n", "      ", 
           RowBox[{"newsolutions", " ", "=", " ", 
            RowBox[{"ParallelTable", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"lazySolver", "[", 
               RowBox[{"yd", ",", " ", 
                RowBox[{"duplicateRootPositions", "[", 
                 RowBox[{"[", "position", "]"}], "]"}], ",", "50", ",", "4"}],
                "]"}], ",", "\n", "          ", 
              RowBox[{"{", 
               RowBox[{"position", ",", " ", 
                RowBox[{"Length", "[", "duplicateRootPositions", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           "\[IndentingNewLine]", 
           RowBox[{"NotebookDelete", "[", 
            RowBox[{"Cells", "[", 
             RowBox[{"CellStyle", " ", "->", " ", "\"\<Print\>\""}], "]"}], 
            "]"}], ";", "\[IndentingNewLine]", "\n", "   ", "\n", "\n", 
           "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Update", " ", "solvedBetheroots", " ", "only", " ", "for", " ", 
             "changed", " ", "positions"}], " ", "*)"}], "\n", "      ", 
           RowBox[{"Do", "[", "\n", "        ", 
            RowBox[{
             RowBox[{
              RowBox[{"solvedBetheroots", "[", 
               RowBox[{"[", 
                RowBox[{"duplicateRootPositions", "[", 
                 RowBox[{"[", "position", "]"}], "]"}], "]"}], "]"}], " ", 
              "=", " ", 
              RowBox[{"newsolutions", "[", 
               RowBox[{"[", " ", "position", "]"}], "]"}]}], ",", "\n", 
             "        ", 
             RowBox[{"{", 
              RowBox[{"position", ",", " ", 
               RowBox[{"Length", "[", "duplicateRootPositions", "]"}]}], 
              "}"}]}], "\n", "      ", "]"}], ";"}], "\[IndentingNewLine]", 
          ",", "\[IndentingNewLine]", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Update", " ", "previous", " ", "duplicate", " ", "positions", " ",
             "before", " ", "next", " ", "iteration"}], " ", "*)"}], "\n", 
          "    ", 
          RowBox[{
           RowBox[{
           "previousDuplicateRootPositions", " ", "=", " ", 
            "duplicateRootPositions"}], ";"}]}], "\n", "\n", "    ", "]"}], 
        ";", "\n", "\n", "\n", "\n", "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Update", " ", "duplicate", " ", "root", " ", "positions", " ", 
          "based", " ", "on", " ", "the", " ", "modified", " ", 
          "solvedBetheroots"}], " ", "*)"}], "\n", "    ", 
        RowBox[{"duplicateRootPositions", " ", "=", " ", 
         RowBox[{
          RowBox[{
          "FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}], "//", 
          "Flatten"}]}], ";"}]}], "\n", "  ", "]"}], ";", "\n", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Return", " ", "the", " ", "updated", " ", "set", " ", "of", " ", 
       "solved", " ", "roots"}], " ", "*)"}], "\n", "  ", 
     "solvedBetheroots"}]}], "\n", "]"}]}]}], "Input",
