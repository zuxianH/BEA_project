Cell[BoxData[
 RowBox[{
  RowBox[{"init\[Theta]rep", "[", "\[Lambda]T_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"init\[Theta]rep", "[", "\[Lambda]T", "]"}], " ", "=", " ", "\n", 
   "   ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"kk", ",", " ", "sd"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"kk", "[", 
        RowBox[{"_", ",", " ", "_"}], "]"}], " ", "=", " ", "0"}], ";", " ", 
      RowBox[{
       RowBox[{"sd", "[", "m_", "]"}], " ", ":=", " ", "\n", "      ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"#1", ",", " ", 
            RowBox[{
             RowBox[{"#1", " ", "<=", " ", "m"}], " ", "&"}]}], " ", "]"}], 
          " ", "&"}], " ", ")"}], " ", "/@", " ", "\[Lambda]T"}]}], ";", " ", 
      "\n", "     ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"CheckStandard", "[", "\[Lambda]T", "]"}], ",", " ", "\n", 
        "      ", 
        RowBox[{"Sort", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"True", " ", "||", " ", "\n", "            ", 
                 RowBox[{"MemberQ", "[", 
                  RowBox[{"DomainOfInterest", ",", " ", 
                   RowBox[{"{", 
                    RowBox[{"a2", ",", " ", "s2"}], "}"}]}], "]"}]}], ",", 
                " ", "\n", "           ", 
                RowBox[{
                 RowBox[{"q\[Theta]", "[", 
                  RowBox[{"a2", ",", " ", "s2", ",", " ", 
                   RowBox[{"++", 
                    RowBox[{"kk", "[", 
                    RowBox[{"a2", ",", " ", "s2"}], "]"}]}]}], "]"}], " ", "->",
                  " ", "\n", "            ", 
                 RowBox[{
                  RowBox[{"Product", "[", 
