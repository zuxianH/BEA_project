                "]"}], ",", "\n", "          ", 
              RowBox[{"{", 
               RowBox[{"position", ",", " ", 
                RowBox[{"Length", "[", "duplicateRootPositions", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\n", "   ", "\n", "\n", "      ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "Update", " ", "solvedBetheroots", " ", "only", " ", "for", " ", 
             "changed", " ", "positions"}], " ", "*)"}], "\n", "      ", 
           RowBox[{"Do", "[", "\n", "        ", 
            RowBox[{
             RowBox[{
              RowBox[{"solvedBetheroots", "[", 
               RowBox[{"[", 
                RowBox[{"duplicateRootPositions", "[", 
                 RowBox[{"[", "position", "]"}], "]"}], "]"}], "]"}], " ", 
              "=", " ", 
              RowBox[{"newsolutions", "[", 
               RowBox[{"[", " ", "position", "]"}], "]"}]}], ",", "\n", 
             "        ", 
             RowBox[{"{", 
              RowBox[{"position", ",", " ", 
               RowBox[{"Length", "[", "duplicateRootPositions", "]"}]}], 
              "}"}]}], "\n", "      ", "]"}], ";"}], "\[IndentingNewLine]", 
          ",", "\[IndentingNewLine]", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Update", " ", "previous", " ", "duplicate", " ", "positions", " ",
             "before", " ", "next", " ", "iteration"}], " ", "*)"}], "\n", 
          "    ", 
          RowBox[{
           RowBox[{
           "previousDuplicateRootPositions", " ", "=", " ", 
            "duplicateRootPositions"}], ";"}]}], "\n", "\n", "    ", "]"}], 
        ";", "\n", "\n", "\n", "\n", "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Update", " ", "duplicate", " ", "root", " ", "positions", " ", 
          "based", " ", "on", " ", "the", " ", "modified", " ", 
          "solvedBetheroots"}], " ", "*)"}], "\n", "    ", 
        RowBox[{"duplicateRootPositions", " ", "=", " ", 
         RowBox[{
          RowBox[{
          "FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}], "//", 
          "Flatten"}]}], ";"}]}], "\n", "  ", "]"}], ";", "\n", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Return", " ", "the", " ", "updated", " ", "set", " ", "of", " ", 
       "solved", " ", "roots"}], " ", "*)"}], "\n", "  ", 
     "solvedBetheroots"}]}], "\n", "]"}]}]}], "Input",
