Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"lazySolver", "[", 
    RowBox[{"yd_", ",", " ", "riggs_", ",", " ", 
     RowBox[{"maxTime_", " ", ":", " ", "40"}], ",", " ", 
     RowBox[{"maxRetries_", " ", ":", " ", "10"}]}], "]"}], " ", ":=", " ", 
   "\n", "  ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "L", ",", " ", "rigs", ",", " ", "mySYT", ",", " ", "attempt", ",", " ",
        "result", ",", " ", "paramValue"}], "}"}], ",", "\n", "    ", "\n", 
     "     ", 
     RowBox[{
      RowBox[{"paramValue", " ", "=", " ", "80"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{"Initial", " ", "value", " ", "of", " ", "parameter"}], " ", 
       "*)"}], "\n", "    ", 
      RowBox[{"L", " ", "=", " ", 
       RowBox[{"Total", "[", "yd", "]"}]}], ";", "\n", "    ", 
      RowBox[{"rigs", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ModestoRiggedConfig", "[", 
          RowBox[{"L", ",", " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
        RowBox[{"ModesConfig", "[", "yd", "]"}]}]}], ";", "\n", "    ", 
      RowBox[{"mySYT", " ", "=", " ", 
       RowBox[{"ToSYT", " ", "/@", " ", "rigs"}]}], ";", "\n", "    ", "\n", 
      "    ", 
      RowBox[{"Print", "[", "riggs", "]"}], ";", "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Retry", " ", "loop", " ", "with", " ", "increasing", " ", "parameter",
         " ", "values"}], " ", "*)"}], "\n", "    ", 
      RowBox[{"attempt", " ", "=", " ", "0"}], ";", "\n", "    ", 
      RowBox[{"result", " ", "=", " ", "$Failed"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Initialize", " ", "result", " ", "to", " ", "failed", " ", "state"}], 
       " ", "*)"}], "\n", "    ", "\n", "    ", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"attempt", " ", "<", " ", "maxRetries"}], " ", "&&", " ", 
         RowBox[{"result", " ", "===", " ", "$Failed"}]}], ",", "\n", 
        "      ", "\n", "      ", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Current paramValue: \>\"", ",", " ", "paramValue"}], 
          "]"}], ";", "\n", "      ", "\n", "      ", 
         RowBox[{"parameter", "[", "paramValue", "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"Set", " ", "parameter", " ", "value"}], " ", "*)"}], "\n", 
         "      ", 
         RowBox[{"attempt", "++"}], ";", "\n", "      ", "\n", "      ", 
         RowBox[{"result", " ", "=", " ", "\n", "        ", 
          RowBox[{"TimeConstrained", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"SolutionFromSYT", "[", 
              RowBox[{"mySYT", "[", 
               RowBox[{"[", "riggs", "]"}], "]"}], "]"}], "//", "Quiet"}], 
            ",", " ", "maxTime", ",", " ", "$Failed"}], "]"}]}], ";", "\n", 
         "        ", 
         RowBox[{"NotebookDelete", "[", 
          RowBox[{"Cells", "[", 
           RowBox[{"CellStyle", " ", "->", " ", "\"\<Print\>\""}], "]"}], 
          "]"}], ";", "\n", "      ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
           "If", " ", "the", " ", "result", " ", "is", " ", "successful"}], 
           ",", " ", 
           RowBox[{"exit", " ", "loop"}]}], " ", "*)"}], "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"result", " ", "=!=", " ", "$Failed"}], ",", " ", 
           RowBox[{"Break", "[", "]"}], ",", 
           RowBox[{"paramValue", " ", "+=", " ", "20"}]}], "]"}], ";"}]}], 
       "\n", "      ", "\n", "      ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Increase", " ", "parameter", " ", "only", " ", "when", " ", 
         "SolutionFromSYT", " ", "fails"}], " ", "*)"}], "\n", "      ", "\n",
        "    ", "]"}], ";", "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"If", " ", "all", " ", "attempts", " ", "failed"}], ",", " ", 
        
        RowBox[{"return", " ", "None", " ", "and", " ", "riggs"}]}], " ", 
       "*)"}], "\n", "    ", 
      RowBox[{"If", "[", 
