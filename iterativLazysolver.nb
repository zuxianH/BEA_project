Cell[BoxData[
 RowBox[{
  RowBox[{"lazySolver", "[", 
   RowBox[{"yd_", ",", " ", "riggs_", ",", " ", 
    RowBox[{"maxTime_", ":", " ", "5"}], ",", " ", 
    RowBox[{"maxRetries_", ":", " ", "2"}]}], "]"}], " ", ":=", " ", "\n", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "L", ",", " ", "rigs", ",", " ", "mySYT", ",", " ", "attempt", ",", " ", 
      "result"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"parameter", "[", "20", "]"}], ";", "\n", "  ", 
     RowBox[{"L", " ", "=", " ", 
      RowBox[{"Total", "[", "yd", "]"}]}], ";", "\n", "  ", 
     RowBox[{"rigs", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ModestoRiggedConfig", "[", 
         RowBox[{"L", ",", " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
       RowBox[{"ModesConfig", "[", "yd", "]"}]}]}], ";", "\n", "  ", 
     RowBox[{"mySYT", " ", "=", " ", 
      RowBox[{"ToSYT", " ", "/@", " ", "rigs"}]}], ";", "\n", "  ", "\n", 
     "  ", 
     RowBox[{"Print", "[", "riggs", "]"}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"(*", 
      RowBox[{"time", " ", "constraint"}], " ", "*)"}], "\n", "  ", 
     RowBox[{"attempt", " ", "=", " ", "0"}], ";", "\n", "  ", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"attempt", " ", "<", " ", "maxRetries"}], ",", " ", "\n", 
       "   ", 
       RowBox[{
        RowBox[{"attempt", "++"}], ";", "\n", "   ", 
        RowBox[{"result", " ", "=", " ", 
         RowBox[{"TimeConstrained", "[", 
          RowBox[{
           RowBox[{"SolutionFromSYT", "[", 
            RowBox[{"mySYT", "[", 
             RowBox[{"[", "riggs", "]"}], "]"}], "]"}], ",", " ", "maxTime", 
           ",", " ", "$Failed"}], "]"}]}], ";", "\n", "   ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"result", " ", "=!=", " ", "$Failed"}], ",", " ", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";"}]}], " ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"If", " ", "it", " ", "succeeds"}], ",", " ", 
        RowBox[{"break", " ", "the", " ", "loop"}]}], " ", "*)"}], "\n", "  ",
       "]"}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"If", " ", "all", " ", "attempts", " ", "failed"}], ",", " ", 
       RowBox[{
       "return", " ", "None", " ", "and", " ", "riggs", " ", 
        "immediately"}]}], " ", "*)"}], "\n", "  ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"result", " ", "===", " ", "$Failed"}], ",", 
       RowBox[{"Return", "[", 
        RowBox[{"None", ",", " ", "riggs"}], "]"}], ",", "\n", "  ", "\n", 
       "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Proceed", " ", "only", " ", "if", " ", "SolutionFromSYT", " ", 
         "succeeded"}], " ", "*)"}], "\n", "  ", "\n", "  ", 
       RowBox[{
        RowBox[{"NotebookDelete", "[", 
         RowBox[{"Cells", "[", 
          RowBox[{"CellStyle", " ", "->", " ", "\"\<Print\>\""}], "]"}], 
         "]"}], ";", "\n", "  ", "\n", "  ", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "allbetheQ", ",", " ", "mysol", ",", " ", "allbetherootEqns", ",", 
            " ", "solvedBetheroots", ",", " ", "\n", "    ", 
            "listCcoefficient", ",", " ", "listUmonomial", ",", " ", 
            "listUmonomialValue", ",", " ", "\n", "    ", 
            "listUmonomialCoffValue"}], "}"}], ",", "\n", "   ", "\n", "   ", 
          
          RowBox[{
           RowBox[{"allbetheQ", " ", "=", " ", 
