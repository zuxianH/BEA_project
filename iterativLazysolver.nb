Cell[BoxData[
 RowBox[{
  RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "roundedBetheRoots", "\[IndentingNewLine]", ",", "tallyBetheRoots", ",", 
      "rootMultiplicity", ",", "duplicatePositions", ",", "duplicateRoots", 
      ",", "duplicateRootPositions", ",", "duplicateRootPositionsFlatten"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"roundedBetheRoots", " ", "=", " ", 
      RowBox[{"Round", "[", 
       RowBox[{
        RowBox[{"solvedBetheroots", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
        RowBox[{"10", "^", 
         RowBox[{"-", "5"}]}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Round", " ", "Bethe", " ", "roots", " ", "to", " ", "5", " ", 
       "decimal", " ", "places"}], " ", "*)"}], "\n", 
     RowBox[{"tallyBetheRoots", " ", "=", " ", 
      RowBox[{"Tally", "[", "roundedBetheRoots", "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Count", " ", "occurrences", " ", "of", " ", "each", " ", "rounded", 
       " ", "root"}], " ", "*)"}], "\n", 
     RowBox[{"rootMultiplicity", " ", "=", " ", 
      RowBox[{"tallyBetheRoots", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Extract", " ", "multiplicities"}], " ", "*)"}], "\n", 
     RowBox[{"duplicatePositions", " ", "=", " ", "\n", "  ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Position", "[", 
        RowBox[{"rootMultiplicity", ",", " ", 
         RowBox[{"x_", " ", "/;", " ", 
          RowBox[{"x", " ", "!=", " ", "1"}]}]}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "Identify", " ", "positions", " ", "where", " ", "multiplicity"}], " ",
        "\[NotEqual]", " ", "1"}], " ", "*)"}], "\n", 
     RowBox[{"duplicateRoots", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"tallyBetheRoots", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "[", 
         RowBox[{"[", "k", "]"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", "duplicatePositions"}], "}"}]}], "]"}]}], ";",
      " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Extract", " ", "duplicate", " ", "roots"}], " ", "*)"}], "\n", 
     
     RowBox[{"duplicateRootPositions", " ", "=", " ", 
      RowBox[{"Table", "[", "\n", "   ", 
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"roundedBetheRoots", ",", " ", 
          RowBox[{"duplicateRoots", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", " ", "\n", "   ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", 
          RowBox[{"Length", "[", "duplicateRoots", "]"}]}], "}"}]}], "\n", 
       "]"}]}], " ", ";", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Find", " ", "positions", " ", "of", " ", "duplicate", " ", "roots", 
       " ", "in", " ", "original", " ", "list"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"duplicateRootPositionsFlatten", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", 
       "duplicateRootPositions"}]}]}]}], "\[IndentingNewLine]", 
