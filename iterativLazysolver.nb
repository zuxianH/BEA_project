Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Loading", " ", "rigged", " ", "configurations", " ", "package"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SetDirectory", "[", 
    RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"<<", "RC.m"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Path", " ", "\[LeftRightArrow]", " ", "Tableaux"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToCrystalPath", "[", "stb_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"stb", "//", "Flatten"}], "]"}]}], "}"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"stb", ",", "k"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "}"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "len"}], "}"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToTableau", "[", "path_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"pr", "=", 
          RowBox[{"path", "//", "Flatten"}]}], ",", "max"}], "}"}], ",", 
       RowBox[{
