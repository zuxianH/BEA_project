Cell[BoxData[
 RowBox[{"GenerateEqnsForNumerics", ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
        "mPrint", "[", 
         "\"\<Generating equations for numerical iterations\>\"", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "normalised", " ", "variables", " ", "and", " ", "equations"}], ",",
           " ", 
          RowBox[{
          "max", " ", "powers", " ", "of", " ", "\[CapitalLambda]", " ", 
           "are", " ", "taken", " ", "out"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"nvars", "=", 
         RowBox[{"vars2", "/.", 
          RowBox[{"c", "\[Rule]", "nc"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sym2nsym", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
            RowBox[{
             SuperscriptBox["\[CapitalLambda]", 
              RowBox[{"n", 
               FractionBox[
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}], "2"]}]], 
             
             RowBox[{"nsym", "[", "n", "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nsym2sym", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"nsym", "[", "n", "]"}], "\[Rule]", 
            RowBox[{
             SuperscriptBox["\[CapitalLambda]", 
              RowBox[{
               RowBox[{"-", "n"}], 
               FractionBox[
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}], "2"]}]], 
             
             RowBox[{"sym", "[", "n", "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"vars2nvars", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{"vars2", ",", 
            RowBox[{"vars2", "/.", 
             RowBox[{
              RowBox[{"c", "[", 
               RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
              
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["\[CapitalLambda]", 
                 RowBox[{"Exponent", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", 
                    "ftransit"}], ",", "\[CapitalLambda]"}], "]"}]], 
                RowBox[{"nc", "[", 
                 RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], ")"}]}]}]}], 
           "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"nvars2vars", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{"nvars", ",", 
            RowBox[{"vars2", "/.", 
             RowBox[{
              RowBox[{"c", "[", 
               RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
              
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["\[CapitalLambda]", 
                 RowBox[{"-", 
                  RowBox[{"Exponent", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", 
                    "ftransit"}], ",", "\[CapitalLambda]"}], "]"}]}]], 
                RowBox[{"c", "[", 
                 RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], ")"}]}]}]}], 
           "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"nfsymrep", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"fsymrep", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "1"}], "]"}], "]"}], "/.", 
             RowBox[{"sym", "\[Rule]", "nsym"}]}], ",", 
            RowBox[{"Collect", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"#", " ", 
                 SuperscriptBox["\[CapitalLambda]", 
                  RowBox[{"-", 
                   RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}]}]]}], "&"}],
                "/@", 
               RowBox[{"fsymrep", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ",", 
              "\[CapitalLambda]"}], "]"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nftransit", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ftransit", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "1"}], "]"}], "]"}], "/.", 
             RowBox[{"c", "\[Rule]", "nc"}]}], ",", 
            RowBox[{"Collect", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"#", " ", 
                 SuperscriptBox["\[CapitalLambda]", 
                  RowBox[{"-", 
                   RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}]}]]}], "&"}],
                "/@", 
               RowBox[{"ftransit", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ",", 
              "\[CapitalLambda]"}], "]"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "these", " ", "is", " ", "the", " ", "rescaled", " ", "version", " ",
           "of", " ", "equations"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"NormedEqns", "=", 
         RowBox[{"Collect", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#", " ", 
              SuperscriptBox["\[CapitalLambda]", 
               RowBox[{"-", 
                RowBox[{"Exponent", "[", 
                 RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}]}]]}], "&"}], "/@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Allrel", "/.", "vars2nvars"}], "/.", "sym2nsym"}], 
             ")"}]}], ",", "\[CapitalLambda]"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", ")"}], "//", "PrintDone"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7897206132240562`*^9, 3.789721120377165*^9}, {
   3.789727306037137*^9, 3.789727487856831*^9}, {3.78973013867163*^9, 
