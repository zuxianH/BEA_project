Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Iteration", " ", "procedure"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Iterate", ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mPrint", "[", 
        RowBox[{
        "\"\<Numerical iterations towards \[CapitalLambda]=\>\"", ",", 
         "\[CapitalLambda]target"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "mPrint", "[", 
        "\"\<If step becomes below \!\(\*SuperscriptBox[\(10\), \(-7\)]\), \
try to increase prec\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"pp", "=", "pmin"}], ";", 
       RowBox[{"qq", "=", "1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"step", ":=", 
        RowBox[{"qq", "/", 
         SuperscriptBox["base", "pp"]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"starting", " ", "the", " ", "procedure"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]Last", "=", 
        RowBox[{"\[CapitalLambda]vals", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"\[CapitalLambda]Last", ">", "\[CapitalLambda]target"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"\[CapitalLambda]new", "=", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{"\[CapitalLambda]Last", "-", "step"}], ",", 
                "\[CapitalLambda]target"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"normedrel", "=", 
              RowBox[{"InterpEqns", "[", "\[CapitalLambda]new", "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Which", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"Catch", "[", "SilentFindSol", "]"}], "===", 
                "\"\<Too big step\>\""}], ",", "\[IndentingNewLine]", 
               RowBox[{"pp", "=", 
                RowBox[{"pp", "+", "1"}]}], ",", "\[IndentingNewLine]", 
               RowBox[{"i", ">", "5"}], ",", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"sol", "[", "\[CapitalLambda]new", "]"}], "=", 
                 "minsolrep"}], ";", "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}],
                  "]"}]}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
               "True", ",", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"sol", "[", "\[CapitalLambda]new", "]"}], "=", 
                 "minsolrep"}], ";", "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}],
                  "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"pp", ">", "pmin"}], ",", 
                  RowBox[{
                   RowBox[{"qq", "=", 
                    RowBox[{"qq", "+", "\[CapitalDelta]q"}]}], ";", 
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"qq", "\[Equal]", "base"}], ",", 
                    RowBox[{
                    RowBox[{"qq", "=", "1"}], ";", 
                    RowBox[{"pp", "=", 
                    RowBox[{"pp", "-", "1"}]}]}]}], "]"}]}]}], "]"}], ";"}]}],
               "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"\[CapitalLambda]Last", "=", 
              RowBox[{"\[CapitalLambda]vals", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}]}]}]}], "\[IndentingNewLine]",
            "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Row", "@", 
           RowBox[{"{", 
            RowBox[{"\"\<Current \[CapitalLambda] is: \>\"", ",", 
             RowBox[{"\[CapitalLambda]Last", "//", "N"}], ",", 
             "\"\<   step is: \>\"", ",", 
             RowBox[{"step", "//", "N"}]}], "}"}]}]}], "]"}], "//", 
        "PrintDone"}], ";", "\[IndentingNewLine]", 
       RowBox[{"mPrint", "[", 
        RowBox[{
        "\"\<Finished iterations. List of all \[CapitalLambda] computed: \
\>\"", ",", " ", 
         RowBox[{"\[CapitalLambda]vals", "//", "N"}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 InitializationCell->True,
