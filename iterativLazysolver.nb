Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "generating", " ", "equations", " ", "using", " ", "asymptotic", " ", 
    "approximation"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"AsymEqns", "[", "\[CapitalLambda]0_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"nsymrep", "=", 
         RowBox[{"nfsymrep", "/.", 
          RowBox[{"\[CapitalLambda]", "->", "\[CapitalLambda]0"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ntransit", "=", 
         RowBox[{"nftransit", "/.", 
          RowBox[{"\[CapitalLambda]", "\[Rule]", "\[CapitalLambda]0"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"subnc", "=", "\[IndentingNewLine]", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{"nvars", ",", 
            RowBox[{
             RowBox[{"nvars", "/.", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"nc", "[", 
                 RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], ":>", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "+", 
                   RowBox[{
                    FractionBox["1", "\[CapitalLambda]0"], 
                    RowBox[{"Sum", "[", 
                    RowBox[{
                    RowBox[{
                    FractionBox["1", 
                    SuperscriptBox["\[CapitalLambda]0", 
                    RowBox[{"ord", "-", "1"}]]], 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"ecc", "[", "ord", "]"}], "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", 
                    RowBox[{"\[CapitalLambda]sol", "[", "ord", "]"}]}], 
                    ")"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"ord", ",", "1", ",", "maxord"}], "}"}]}], 
                    "]"}]}]}], ")"}], 
                 RowBox[{"nc", "[", 
                  RowBox[{"a", ",", "s", ",", "k"}], "]"}]}]}], ")"}]}], "/.",
              "ntransit"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"#", "/", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"Abs", "[", 
               RowBox[{"#", "/.", 
                RowBox[{
                 RowBox[{"nc", "[", 
                  RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], 
                 "\[RuleDelayed]", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"nc", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", "subnc"}],
                   ")"}]}]}], "]"}]}], ")"}]}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"NormedEqns", "/.", "nsymrep"}], "/.", 
            RowBox[{"\[CapitalLambda]", "\[Rule]", "\[CapitalLambda]0"}]}], 
           ")"}]}], "//", "Expand"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "generating", " ", "equations", " ", "using", " ", "previous", " ", 
     "order", " ", "results", " ", "and", " ", "polynomial", " ", "fit"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"InterpEqns", "[", "\[CapitalLambda]0_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"minterpord", "=", 
         RowBox[{"Min", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "\[CapitalLambda]vals", "]"}], "-", "1"}], 
           ",", "interpord"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"nsymrep", "=", 
         RowBox[{"nfsymrep", "/.", 
          RowBox[{"\[CapitalLambda]", "->", "\[CapitalLambda]0"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"subnc", "=", "\[IndentingNewLine]", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{"nvars", ",", 
            RowBox[{"Round", "[", 
             RowBox[{
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"nvars", "/.", 
                   RowBox[{"sol", "[", 
                    RowBox[{"\[CapitalLambda]vals", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "]"}]}], ")"}], 
                 RowBox[{"Product", "[", 
                  RowBox[{
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"j", "\[Equal]", "j2"}], ",", "1", ",", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"\[CapitalLambda]0", "-", 
                    RowBox[{"\[CapitalLambda]vals", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j2"}], "]"}], "]"}]}], ")"}], "/", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"\[CapitalLambda]vals", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j"}], "]"}], "]"}], "-", 
                    RowBox[{"\[CapitalLambda]vals", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "j2"}], "]"}], "]"}]}], ")"}]}]}], "]"}], 
                   ",", 
                   RowBox[{"{", 
                    RowBox[{"j2", ",", "minterpord"}], "}"}]}], "]"}]}], ",", 
                
                RowBox[{"{", 
                 RowBox[{"j", ",", "minterpord"}], "}"}]}], "]"}], ",", 
              SuperscriptBox["10", 
               RowBox[{"-", "prec"}]]}], "]"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"#", "/", 
            RowBox[{"(", 
             RowBox[{"#", "/.", 
              RowBox[{
               RowBox[{"nc", "[", 
                RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]",
                " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    RowBox[{"Round", "[", 
                    RowBox[{
                    FractionBox[
                    RowBox[{"Random", "[", "]"}], "100"], ",", 
                    SuperscriptBox["10", 
                    RowBox[{"-", "5"}]]}], "]"}]}], ")"}], 
                  RowBox[{"nc", "[", 
                   RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], "/.", 
                 "subnc"}], ")"}]}]}], ")"}]}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"NormedEqns", "/.", "nsymrep"}], "/.", 
            RowBox[{"\[CapitalLambda]", "\[Rule]", "\[CapitalLambda]0"}]}], 
           ")"}]}], "//", "Expand"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Routine", " ", "to", " ", "produce", " ", "solution"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FindSol", ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ";", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"minim", ",", "minsolrep"}], "}"}], "=", 
        RowBox[{"Monitor", "[", 
         RowBox[{
          RowBox[{"FindMinimum", "[", 
           RowBox[{
            RowBox[{"normedrel", ".", "normedrel"}], ",", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"nvars", ",", 
               RowBox[{"nvars", "/.", "subnc"}]}], "}"}], "//", "Transpose"}],
             ",", 
            RowBox[{"WorkingPrecision", "\[Rule]", "prec"}], ",", 
            RowBox[{"PrecisionGoal", "\[Rule]", "Infinity"}], ",", 
            RowBox[{"AccuracyGoal", "\[Rule]", 
             RowBox[{"prec", "/", "2"}]}], ",", 
            RowBox[{"MaxIterations", "\[Rule]", "50"}], ",", 
            RowBox[{"Method", "\[Rule]", "Automatic"}], ",", 
            RowBox[{"EvaluationMonitor", "\[RuleDelayed]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"i", "++"}], ";", 
               RowBox[{"norm", "=", 
                RowBox[{
                 RowBox[{"normedrel", ".", "normedrel"}], "//", "N"}]}], ";", 
               
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"i", ">", "MyMaxIterations"}], ",", 
                 RowBox[{"Throw", "[", "\"\<Too big step\>\"", "]"}]}], 
                "]"}]}], ")"}]}]}], "]"}], ",", 
          RowBox[{"Row", "@", 
           RowBox[{"{", 
            RowBox[{
            "\"\<Step: \>\"", " ", ",", "i", ",", "\"\<,   Minim: \>\"", ",", 
             "norm"}], "}"}]}]}], "]"}]}]}], ")"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SilentFindSol", ":=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ";", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"minim", ",", "minsolrep"}], "}"}], "=", 
        RowBox[{"FindMinimum", "[", 
         RowBox[{
          RowBox[{"normedrel", ".", "normedrel"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"nvars", ",", 
             RowBox[{"nvars", "/.", "subnc"}]}], "}"}], "//", "Transpose"}], 
          ",", 
          RowBox[{"WorkingPrecision", "\[Rule]", "prec"}], ",", 
          RowBox[{"PrecisionGoal", "\[Rule]", "Infinity"}], ",", 
          RowBox[{"AccuracyGoal", "\[Rule]", 
           RowBox[{"prec", "/", "2"}]}], ",", 
          RowBox[{"MaxIterations", "\[Rule]", "50"}], ",", 
          RowBox[{"Method", "\[Rule]", "Automatic"}], ",", 
          RowBox[{"EvaluationMonitor", "\[RuleDelayed]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"i", "++"}], ";", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"i", ">", "MyMaxIterations"}], ",", 
               RowBox[{"Throw", "[", "\"\<Too big step\>\"", "]"}]}], "]"}]}],
             ")"}]}]}], "]"}]}]}], ")"}]}], ";"}]}]}]], "Input",
