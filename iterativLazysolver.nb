     RowBox[{
      RowBox[{"Plus", " ", "@@", " ", "\[Lambda]"}], "!"}], "/", 
     RowBox[{"Product", "[", "\n", "     ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Lambda]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Length", "[", "\[Lambda]", "]"}], " ", "-", " ", "a"}],
              "]"}], "]"}], " ", "+", " ", "a"}], ")"}], "!"}], "/", "\n", 
        "      ", 
        RowBox[{"Product", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Lambda]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Length", "[", "\[Lambda]", "]"}], " ", "-", " ", "a"}],
              "]"}], "]"}], " ", "-", " ", "\n", "        ", 
           RowBox[{"\[Lambda]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Length", "[", "\[Lambda]", "]"}], " ", "-", " ", "k"}],
              "]"}], "]"}], " ", "+", " ", 
           RowBox[{"(", 
            RowBox[{"a", " ", "-", " ", "k"}], ")"}]}], ",", " ", "\n", 
