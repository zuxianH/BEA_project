          RowBox[{
           RowBox[{"\[Theta]", "[", "i_", "]"}], "\[RuleDelayed]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"i", "==", 
              RowBox[{"(", 
               RowBox[{"\[Lambda]Tcurrent", "//", "Max"}], ")"}]}], ",", 
             "\[CapitalLambda]", ",", "0"}], "]"}]}]}]}], ";", " ", 
        "\[IndentingNewLine]", 
        RowBox[{"fsymrepUptd", "=", 
