          RowBox[{"init\[Theta]rep", "[", "\[Lambda]Tcurrent", "]"}], "/.", 
          RowBox[{
           RowBox[{"\[Theta]", "[", "i_", "]"}], "\[RuleDelayed]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"i", "==", 
              RowBox[{"(", 
               RowBox[{"\[Lambda]Tcurrent", "//", "Max"}], ")"}]}], ",", 
             "\[CapitalLambda]", ",", "0"}], "]"}]}]}]}], ";", " ", 
        "\[IndentingNewLine]", 
        RowBox[{"fsymrepUptd", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
            RowBox[{"Expand", "@", 
             RowBox[{"Coefficient", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Product", "[", 
                 RowBox[{"u", ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", 
                    RowBox[{"Len", "-", "1"}]}], "}"}]}], "]"}], 
                RowBox[{"(", 
                 RowBox[{"u", "-", "\[CapitalLambda]"}], ")"}]}], ",", "u", ",", 
               RowBox[{"Len", "-", "n"}]}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ftransitUptdInterim", "=", 
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"a", "+", "s"}], "\[Equal]", "0"}], "||", 
                    RowBox[{"Not", "@", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"vars2", ",", 
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "1"}], "]"}]}], "]"}]}]}], ",",
                    "Nothing", ",", 
                   RowBox[{"CoefficientList", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"YQa", "[", 
                    RowBox[{"a", ",", "s", ",", "\[Lambda]current"}], "]"}], "-", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
