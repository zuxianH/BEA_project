                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"YQ\[Theta]", "[", 
                    RowBox[{"a", ",", "s", ",", "\[Lambda]"}], "]"}], "/.", 
                    "\[CapitalLambda]init\[Theta]repUptd"}], ")"}]}], ",", 
                    "u"}], "]"}]}], "]"}], ",", 
                RowBox[{"{", 
