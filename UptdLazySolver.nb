                RowBox[{"(", 
                 RowBox[{"u", "-", "\[CapitalLambda]"}], ")"}]}], ",", "u", ",", 
               RowBox[{"Len", "-", "n"}]}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ftransitUptdInterim", "=", 
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
