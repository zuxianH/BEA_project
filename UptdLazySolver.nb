          RowBox[{
           RowBox[{
            RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
            RowBox[{"Expand", "@", 
             RowBox[{"Coefficient", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Product", "[", 
                 RowBox[{"u", ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", 
