          RowBox[{"Select", "[", 
           RowBox[{"#1", ",", " ", 
            RowBox[{
             RowBox[{"#1", " ", "<=", " ", "m"}], " ", "&"}]}], " ", "]"}], 
          " ", "&"}], " ", ")"}], " ", "/@", " ", "\[Lambda]T"}]}], ";", " ", 
