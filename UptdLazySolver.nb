Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
    "Large\[CapitalLambda]ExpansionUptdStart", "[", "\[Lambda]T_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Lambda]", ",", "Len"}], "}"}], ",", 
      RowBox[{
       RowBox[{"\[Lambda]", "=", 
        RowBox[{"\[Lambda]T", "//", "ToYD"}]}], ";", 
       RowBox[{"Len", "=", 
        RowBox[{"Total", "[", "\[Lambda]", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[CapitalLambda]init\[Theta]repUptd", "=", 
          RowBox[{
           RowBox[{"init\[Theta]rep", "[", "\[Lambda]T", "]"}], "/.", 
           RowBox[{
            RowBox[{"\[Theta]", "[", "i_", "]"}], "\[RuleDelayed]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", "==", 
               RowBox[{"(", 
                RowBox[{"\[Lambda]T", "//", "Max"}], ")"}]}], ",", 
              "\[CapitalLambda]", ",", "0"}], "]"}]}]}]}], ";", "  ", 
         RowBox[{"(*", 
          RowBox[{
          "The", " ", "set", " ", "of", "  ", "q\[Theta]", " ", "for", " ", 
           "the", " ", "initial", " ", "\[Lambda]T", " ", "will", " ", "be", " ",
            "used", " ", "here"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"fsymrepUptd", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
             RowBox[{"Expand", "@", 
              RowBox[{"Coefficient", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Product", "[", 
                  RowBox[{"u", ",", 
                   RowBox[{"{", 
                    RowBox[{"i", ",", 
                    RowBox[{"Len", "-", "1"}]}], "}"}]}], "]"}], 
                 RowBox[{"(", 
                  RowBox[{"u", "-", "\[CapitalLambda]"}], ")"}]}], ",", "u", ",", 
                RowBox[{"Len", "-", "n"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ftransitUptd", "=", 
          RowBox[{
           RowBox[{"Solve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"a", "+", "s"}], "\[Equal]", "0"}], "||", 
                    RowBox[{"Not", "@", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"vars2", ",", 
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "1"}], "]"}]}], "]"}]}]}], ",",
                     "Nothing", ",", 
                    RowBox[{"CoefficientList", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"YQa", "[", 
                    RowBox[{"a", ",", "s", ",", "\[Lambda]"}], "]"}], "-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"YQ\[Theta]", "[", 
                    RowBox[{"a", ",", "s", ",", "\[Lambda]"}], "]"}], "/.", 
                    "\[CapitalLambda]init\[Theta]repUptd"}], ")"}]}], ",", 
                    "u"}], "]"}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"a", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
                   "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"s", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"\[Lambda]", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], 
                   "}"}]}], "]"}], "//", "Flatten"}], ")"}], "\[Equal]", 
              "0"}], ",", "vars2"}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"anlyticUptd", "=", 
          RowBox[{"Collect", "[", 
