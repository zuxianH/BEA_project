Cell[BoxData[{
 RowBox[{
  RowBox[{"SolutionFromSYTUptdStart", "[", "SYT_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Lambda]Tstart", ",", "\[Lambda]start"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Solve", " ", "the", " ", "initial", " ", 
       RowBox[{"YT", "--"}]}], "-", 
      RowBox[{
      "one", " ", "row", " ", "with", " ", "increasing", " ", "tableau", " ", 
       "values"}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Steps", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]Tstart", "=", "SYT"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]start", "=", 
      RowBox[{"\[Lambda]Tstart", "//", "ToYD"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"GenerateQsystem", "[", "\[Lambda]start", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Large\[CapitalLambda]ExpansionUptdStart", "[", "\[Lambda]Tstart", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"SubleadingOrdersUptdStart", ";"}], "*)"}], 
     "\[IndentingNewLine]", "GenerateSolsFromAsymptoticsUptdStart", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalLambda]vals", "=", "\[CapitalLambda]vals0"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"IterateUptd", "[", "\[Lambda]Tstart", "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"SolutionFromSYTUptdInterim", "[", 
   RowBox[{"SYTcurrent_", ",", "SYTlast_", ",", "solnlast_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Lambda]Tinterim", ",", "\[Lambda]Tlast", ",", "\[Lambda]interim"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Steps", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]Tinterim", "=", "SYTcurrent"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]Tlast", "=", "SYTlast"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]interim", "=", 
      RowBox[{"\[Lambda]Tinterim", "//", "ToYD"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"GenerateQsystem", "[", "\[Lambda]interim", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Large\[CapitalLambda]ExpansionUptdInterim", "[", 
      RowBox[{"\[Lambda]Tinterim", ",", "\[Lambda]Tlast", ",", "solnlast"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"SubleadingOrdersUptdInterim", ";"}], "*)"}], 
     "\[IndentingNewLine]", "GenerateSolsFromAsymptoticsUptdInterim", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalLambda]vals", "=", "\[CapitalLambda]vals0"}], ";", 
