                 RowBox[{"c", "[", 
                  RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "+", 
                   RowBox[{"Sum", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"ecc", "[", "ord", "]"}], "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
                    SuperscriptBox["\[CapitalLambda]", 
                    RowBox[{
                    RowBox[{"-", "ord"}], "+", "1"}]]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"ord", ",", "maxord"}], "}"}]}], "]"}]}], 
                  ")"}]}]}], "/.", "ftransitUptd"}], ")"}], "//", "Expand"}], 
            ",", "\[CapitalLambda]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
        ")"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
