   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"SolutionFromSYTUptdStepwise", "[", "SYT_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[Lambda]Tlist", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"StepsWholeIteration", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ansWholeIteration", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]Tlist", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"MemberQ", "[", 
              RowBox[{
               RowBox[{"Range", "[", 
                RowBox[{"1", ",", "i"}], "]"}], ",", "#"}], "]"}], "&"}], 
            "]"}], "/@", "SYT"}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", "}"}], "->", "Nothing"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Count", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"SYT", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "-", 
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{"SYT", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "//", "Length"}], "]"}]}], ",",
              "0"}], "]"}], ",", 
           RowBox[{"SYT", "//", "Max"}]}], "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"2", ";;"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SolutionFromSYTUptdStart", "[", 
      RowBox[{"\[Lambda]Tlist", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}], ";", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"StepsWholeIteration", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[CapitalLambda]vals", "[", 
            RowBox[{"[", "#", "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Thread", "[", 
