Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"urootsStringHypothesisNonlog", "[", 
    RowBox[{
    "L_", ",", "M_", ",", "\[Epsilon]Start_", ",", "\[Epsilon]Steps_"}], 
    "]"}], ":=", " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"MAIN", " ", 
      RowBox[{"FUNCTION", ".", " ", "Produces"}], " ", "a", " ", "list", " ", 
      "of", " ", "the", " ", "uroots"}], ",", " ", 
     RowBox[{
     "indexed", " ", "by", " ", "the", " ", "mode", " ", "numbers", " ", 
      "giving", " ", "this", " ", 
      RowBox[{"solution", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Mset", ",", "stringsets", ",", "stringsetsPerm", ",", "\[Epsilon]list",
        ",", "modes", ",", "ustart", ",", "modesforstring", ",", "BAElog", 
       ",", "solutions", ",", "MM", ",", "v", ",", "u"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Epsilon]list", "=", 
       RowBox[{"Range", "[", 
        RowBox[{"\[Epsilon]Start", ",", "1", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Epsilon]Start"}], ")"}], "/", 
          "\[Epsilon]Steps"}]}], "]"}]}], ";", " ", 
      RowBox[{"(*", 
       RowBox[{
       "The", " ", "list", " ", "of", " ", "epislon", " ", "values", " ", 
        "to", " ", "iterate", " ", "over"}], "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"stringsets", "=", 
       RowBox[{"Sort", "/@", 
        RowBox[{"IntegerPartitions", "[", "M", "]"}]}]}], ";", " ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"All", " ", "possible", " ", "stringvectors"}], ";", " ", 
         RowBox[{
         "the", " ", "entries", " ", "are", " ", "the", " ", "strings"}]}], 
        ",", " ", 
        RowBox[{
         RowBox[{
         "with", " ", "values", " ", "corresponding", " ", "to", " ", "the", 
          " ", "length", " ", "of", " ", "these", " ", "strings"}], ";", " ", 
