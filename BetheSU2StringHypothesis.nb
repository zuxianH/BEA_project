       ";"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Alternative", ",", " ", 
       RowBox[{
       "if", " ", "we", " ", "supply", " ", "Mset", " ", "instead", " ", "of",
         " ", "stringsets"}]}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"BAElog", "[", 
