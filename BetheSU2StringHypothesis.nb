Cell[BoxData[
 RowBox[{
  RowBox[{"urootsStringHypothesisTestforBAE", "[", 
   RowBox[{"L_", ",", "answers_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"BAEfunctions", ",", "u", ",", "magnon"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"magnon", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"answers", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], "//", "Total"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"BAEfunctions", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u", "[", "k", "]"}], "+", 
             RowBox[{"I", "/", "2"}]}], ")"}], "^", "L"}], " ", "*", 
          RowBox[{"Product", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"u", "[", "k", "]"}], "-", 
               RowBox[{"u", "[", "j", "]"}], "-", "I"}], ")"}], "^", 
             RowBox[{"Boole", "[", 
              RowBox[{"j", "!=", "k"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "magnon"}], "}"}]}], "]"}]}], "-", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u", "[", "k", "]"}], "-", 
             RowBox[{"I", "/", "2"}]}], ")"}], "^", "L"}], "*", 
          RowBox[{"Product", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"u", "[", "k", "]"}], "-", 
               RowBox[{"u", "[", "j", "]"}], "+", "I"}], ")"}], "^", 
             RowBox[{"Boole", "[", 
              RowBox[{"j", "!=", "k"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "magnon"}], "}"}]}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "magnon"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"answers", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"answers", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"AllTrue", "[", 
              RowBox[{
               RowBox[{"Abs", "/@", 
                RowBox[{"(", 
                 RowBox[{"BAEfunctions", "/.", 
                  RowBox[{"AssociationThread", "[", 
                   RowBox[{
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"u", "[", "j", "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", "1", ",", "magnon"}], "}"}]}], "]"}], 
                    ",", 
                    RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "//", "Flatten"}]}], 
                   "]"}]}], ")"}]}], ",", 
               RowBox[{"LessThan", "[", "10", "]"}]}], "]"}], "&&", 
             RowBox[{"AllTrue", "[", 
              RowBox[{
               RowBox[{"Abs", "/@", 
                RowBox[{"Flatten", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", 
               RowBox[{"LessThan", "[", 
                RowBox[{"10", "^", "5"}], "]"}]}], "]"}]}], "&"}]}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "answers", "]"}]}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Provides", " ", "only", " ", "those", " ", "solutions", " ", "that", " ",
