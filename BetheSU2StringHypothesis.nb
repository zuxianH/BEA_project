Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ustart", "[", 
     RowBox[{"length_", ",", "magnon_", ",", "stringvec_", ",", "modevec_"}], 
     "]"}], ":=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"length", "/", "Pi"}], ")"}]}], "*", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"2", 
               RowBox[{"u", "[", "i", "]"}]}], "+", 
              RowBox[{"I", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"stringvec", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "-", "1", "-", 
                 RowBox[{"2", "k"}]}], ")"}]}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "0", ",", 
              RowBox[{
               RowBox[{"stringvec", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
           "]"}]}], "==", 
         RowBox[{"modevec", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ",", 
        RowBox[{"u", "[", "i", "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "stringvec", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
