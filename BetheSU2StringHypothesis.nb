                    RowBox[{"stringvec", "[", 
                    RowBox[{"[", "string", "]"}], "]"}], "+", 
                    RowBox[{"stringvec", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "/", "2"}], "-", 
