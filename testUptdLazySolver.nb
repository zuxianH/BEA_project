 RowBox[{
  RowBox[{"SolutionFromSYTUptdStepwise", "[", "SYT_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[Lambda]Tlist", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"StepsStepwise", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ansWholeIteration", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]Tlist", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"MemberQ", "[", 
              RowBox[{
               RowBox[{"Range", "[", 
                RowBox[{"1", ",", "i"}], "]"}], ",", "#"}], "]"}], "&"}], 
            "]"}], "/@", "SYT"}], "/.", 
