      "one", " ", "row", " ", "with", " ", "increasing", " ", "tableau", " ", 
       "values", " ", "and", " ", "one", " ", "box", " ", "in", " ", "the", " ",
        "next", " ", "row"}]}], "*)"}], "\[IndentingNewLine]", 
