Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Iteration", " ", "procedure"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"IterateUptd", "[", "SYT_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pp", "=", "pmin"}], ";", 
        RowBox[{"qq", "=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"step", ":=", 
         RowBox[{"qq", "/", 
          SuperscriptBox["base", "pp"]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"starting", " ", "the", " ", "procedure"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"\[CapitalLambda]Last", "=", 
         RowBox[{"\[CapitalLambda]vals", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"\[CapitalLambda]Last", ">", "\[CapitalLambda]target"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"step", "<", 
               RowBox[{"10", "^", 
                RowBox[{"-", "20"}]}]}], ",", 
              RowBox[{
               RowBox[{"Print", "[", 
                RowBox[{"{", 
                 RowBox[{"SYT", ",", 
                  RowBox[{"step", "//", "N"}], ",", 
                  RowBox[{"\[CapitalLambda]vals", "//", "N"}]}], "}"}], "]"}],
                ";", 
               RowBox[{"Break", "[", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"\[CapitalLambda]new", "=", 
                RowBox[{"Max", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalLambda]Last", "-", "step"}], ",", 
                  "\[CapitalLambda]target"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"normedrel", "=", 
                RowBox[{"InterpEqnsUptd", "[", "\[CapitalLambda]new", "]"}]}],
                ";", "\[IndentingNewLine]", 
               RowBox[{"Which", "[", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Catch", "[", "FindSolUptd", "]"}], "===", 
                  RowBox[{"Too", " ", "big", " ", "step"}]}], ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"pp", "=", 
                  RowBox[{"pp", "+", "1"}]}], ",", "\[IndentingNewLine]", 
                 RowBox[{"i", ">", "5"}], ",", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"sol", "[", "\[CapitalLambda]new", "]"}], "=", 
                   "minsolrep"}], ";", "\[IndentingNewLine]", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{
                   "\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}], 
                   "]"}]}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]",
                  "True", ",", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"sol", "[", "\[CapitalLambda]new", "]"}], "=", 
                   "minsolrep"}], ";", "\[IndentingNewLine]", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{
                   "\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}], 
                   "]"}], ";", "\[IndentingNewLine]", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"pp", ">", "pmin"}], ",", 
                    RowBox[{
                    RowBox[{"qq", "=", 
                    RowBox[{"qq", "+", "\[CapitalDelta]q"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"qq", "\[Equal]", "base"}], ",", 
                    RowBox[{
                    RowBox[{"qq", "=", "1"}], ";", 
                    RowBox[{"pp", "=", 
                    RowBox[{"pp", "-", "1"}]}]}]}], "]"}]}]}], "]"}], ";"}]}],
                 "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
               RowBox[{"\[CapitalLambda]Last", "=", 
                RowBox[{"\[CapitalLambda]vals", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}]}], ";"}]}], 
             "\[IndentingNewLine]", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Row", "@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Current", " ", "\[CapitalLambda]", " ", "history", " ", 
              RowBox[{"is", ":"}]}], " ", ",", 
             RowBox[{"\[CapitalLambda]vals", "//", "N"}], ",", 
             RowBox[{"current", " ", "\[CapitalLambda]", " ", 
              RowBox[{"is", ":"}]}], " ", ",", 
             RowBox[{"\[CapitalLambda]Last", "//", "N"}], ",", "    ", 
             RowBox[{"step", " ", 
              RowBox[{"is", ":"}]}], " ", ",", 
             RowBox[{"step", "//", "N"}]}], "}"}]}]}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"IterateUptd", "[", "SYT_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"pp", "=", "pmin"}], ";", 
        RowBox[{"qq", "=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"step", ":=", 
         RowBox[{"qq", "/", 
          SuperscriptBox["base", "pp"]}]}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"starting", " ", "the", " ", "procedure"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[CapitalLambda]Last", "=", 
        RowBox[{"\[CapitalLambda]vals", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{"\[CapitalLambda]Last", ">", "\[CapitalLambda]target"}], ",",
            "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\[CapitalLambda]new", "=", 
             RowBox[{"Max", "[", 
              RowBox[{
               RowBox[{"\[CapitalLambda]Last", "-", "step"}], ",", 
               "\[CapitalLambda]target"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"normedrel", "=", 
             RowBox[{"InterpEqnsUptd", "[", "\[CapitalLambda]new", "]"}]}], ";",
             "\[IndentingNewLine]", "FindSolUptd", ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"sol", "[", "\[CapitalLambda]new", "]"}], "=", 
             "minsolrep"}], ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}], 
             "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"\[CapitalLambda]Last", "=", 
             RowBox[{"\[CapitalLambda]vals", "[", 
              RowBox[{"[", 
               RowBox[{"-", "1"}], "]"}], "]"}]}], ";"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Row", "@", 
          RowBox[{"{", 
           RowBox[{"\"\<Current \[CapitalLambda] history is: \>\"", ",", 
            RowBox[{"\[CapitalLambda]vals", "//", "N"}], 
            ",", "\"\< current \[CapitalLambda] is: \>\"", ",", 
            RowBox[{"\[CapitalLambda]Last", "//", "N"}], 
            ",", "\"\< step is: \>\"", ",", 
            RowBox[{"step", "//", "N"}]}], "}"}]}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
