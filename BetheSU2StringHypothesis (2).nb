Cell[BoxData[
 RowBox[{
  RowBox[{"urootsStringHypothesis", "[", 
   RowBox[{
   "L_", ",", "M_", ",", "\[Epsilon]Start_", ",", "\[Epsilon]Steps_"}], "]"}],
   ":=", " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"MAIN", " ", 
     RowBox[{"FUNCTION", ".", " ", "Produces"}], " ", "a", " ", "list", " ", 
     "of", " ", "the", " ", "uroots"}], ",", " ", 
    RowBox[{
    "indexed", " ", "by", " ", "the", " ", "mode", " ", "numbers", " ", 
     "giving", " ", "this", " ", 
     RowBox[{"solution", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Mset", ",", "stringsets", ",", "stringsetsPerm", ",", "\[Epsilon]list", 
      ",", "modes"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Epsilon]list", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"\[Epsilon]Start", ",", "1", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Epsilon]Start"}], ")"}], "/", 
         "\[Epsilon]Steps"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "The", " ", "list", " ", "of", " ", "epislon", " ", "values", " ", "to",
        " ", "iterate", " ", "over"}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Mset", "=", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"s", "*", 
             RowBox[{"MM", "[", "s", "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"s", ",", "1", ",", "M"}], "}"}]}], "]"}], "==", "M"}], 
         ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"MM", "[", "t", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "1", ",", "M"}], "}"}]}], "]"}], ",", 
         "NonNegativeIntegers"}], "]"}], "//", "Values"}]}], ";", 
     "\[IndentingNewLine]", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"All", " ", "possible", " ", "Ms", " ", "sets"}], ";", 
       RowBox[{
       "the", " ", "index", " ", "is", " ", "the", " ", "string", " ", 
        "length", " ", "and", " ", "the", " ", "value", " ", "is", " ", "the",
         " ", "number", " ", "of", " ", "strings", " ", "of", " ", "that", 
        " ", "length"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"stringsets", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Catenate", "[", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{"i", ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", 
               RowBox[{"set", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "set", "]"}]}], "}"}]}], "]"}], "]"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"set", ",", "Mset"}], "}"}]}], "]"}]}], ";", " ", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"All", " ", "possible", " ", "stringvectors"}], ";", " ", 
        RowBox[{
        "the", " ", "entries", " ", "are", " ", "the", " ", "strings"}]}], 
       ",", " ", 
       RowBox[{
        RowBox[{
        "with", " ", "values", " ", "corresponding", " ", "to", " ", "the", 
         " ", "length", " ", "of", " ", "these", " ", "strings"}], ";", " ", 
        RowBox[{
         RowBox[{"stringsets", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "==", 
         "\"\<length of string i\>\""}]}]}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"modesforstring", "[", 
       RowBox[{"length_", ",", "magnon_", ",", "stringlength_"}], "]"}], ":=",
       " ", 
      RowBox[{"Range", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "stringlength"}], "*", 
          RowBox[{"length", "/", "2"}]}], "+", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "stringlength"}], "*", 
          "stringlength", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"magnon", "-", "1"}], ")"}], "/", "2"}]}]}], ",", 
        RowBox[{
         RowBox[{"stringlength", "*", 
          RowBox[{"length", "/", "2"}]}], "-", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "stringlength"}], "*", 
          "stringlength", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"magnon", "-", "1"}], ")"}], "/", "2"}]}]}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"modes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Tuples", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"modesforstring", "[", 
            RowBox[{"L", ",", "M", ",", "#"}], "]"}], "&"}], "/@", 
          RowBox[{"stringsets", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "stringsets", "]"}]}], "}"}]}], "]"}]}], ";",
      " ", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "The", " ", "list", " ", "of", " ", "all", " ", "possible", " ", 
        "modes", " ", "for", " ", "all", " ", "possible", " ", 
        "stringvectors", " ", 
        RowBox[{"(", 
