           RowBox[{
            RowBox[{"{", "}"}], "->", 
            RowBox[{"u", "->", "0"}]}]}], "//", "Values"}], "//", "Flatten"}],
         "//", "Re"}], ")"}], "+", 
      RowBox[{"10", "^", 
       RowBox[{"-", "3"}]}]}], "/.", 
     RowBox[{"ComplexInfinity", "->", 
      RowBox[{"10", "^", "15"}]}]}]}], ";"}], " "}]], "Input",
