                RowBox[{"2", "k"}]}], ")"}]}]}], ",", 
            RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", 
            RowBox[{
             RowBox[{"stringvec", "[", 
              RowBox[{"[", "string", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
         "]"}]}], "-", 
       RowBox[{"epsilon", "\[IndentingNewLine]", "*", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"string", "==", "j"}], ",", "0", ",", 
