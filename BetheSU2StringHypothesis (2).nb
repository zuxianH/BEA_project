Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mset", "=", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"s", "*", 
           RowBox[{"MM", "[", "s", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "1", ",", "3"}], "}"}]}], "]"}], "==", "3"}], 
       ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"MM", "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1", ",", "3"}], "}"}]}], "]"}], ",", 
       "NonNegativeIntegers"}], "]"}], "//", "Values"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"All", " ", "possible", " ", "Ms", " ", "sets"}], ";", 
    RowBox[{
    "the", " ", "index", " ", "is", " ", "the", " ", "string", " ", "length", 
     " ", "and", " ", "the", " ", "value", " ", "is", " ", "the", " ", 
     "number", " ", "of", " ", "strings", " ", "of", " ", "that", " ", 
     "length"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"stringsets", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Catenate", "[", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{"i", ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"set", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "set", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"set", ",", "Mset"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"All", " ", "possible", " ", "stringvectors"}], ";", " ", 
     RowBox[{
     "the", " ", "entries", " ", "are", " ", "the", " ", "strings"}]}], ",", 
    " ", 
    RowBox[{
     RowBox[{
     "with", " ", "values", " ", "corresponding", " ", "to", " ", "the", " ", 
      "length", " ", "of", " ", "these", " ", "strings"}], ";", " ", 
     RowBox[{
      RowBox[{"stringsets", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "==", 
      "\"\<length of string i\>\""}]}]}], "*)"}]}]}], "Input",
