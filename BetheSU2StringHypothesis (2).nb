                   RowBox[{"v", "[", "j", "]"}], "-", 
                   RowBox[{"I", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"stringvec", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "-", "1", "-", 
                    RowBox[{"2", "kk"}]}], ")"}], "/", "2"}]}]}], ",", 
                  RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", 
                RowBox[{"{", 
