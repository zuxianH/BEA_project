          " ", "the", " ", "mode", " ", "number"}]}], ",", " ", 
       RowBox[{
       "depending", " ", "on", " ", "the", " ", "string", " ", "length", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"1", "/", "2"}], " ", "if", " ", "the", " ", "length", " ", 
          "is", " ", "even"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"BAElog", "[", 
       RowBox[{
       "length_", ",", "stringvec_", ",", "string_", ",", "modenumber_", ",", 
        "epsilon_"}], "]"}], ":=", 
      RowBox[{
       RowBox[{"length", "*", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"Fsym", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", 
              RowBox[{"v", "[", "string", "]"}]}], "+", 
             RowBox[{"I", 
              RowBox[{"(", 
