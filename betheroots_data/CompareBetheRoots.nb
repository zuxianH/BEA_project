     "set"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AdmissibleModes", "[", "yd_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "Mmatrices", "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"Mmatrices", "=", 
       RowBox[{"Msetmatrix", "[", "yd", "]"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"Table", "[", "\n", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "Holes", ",", "M\[LetterSpace]removeFirstLastZero", ",", 
             "Holes\[LetterSpace]removeFirstLastZero"}], "}"}], ",", "\n", 
           "\n", 
           RowBox[{
            RowBox[{"Holes", "=", 
             RowBox[{"-", 
              RowBox[{
               RowBox[{"Cartan", "[", 
                RowBox[{"Length", "[", "Mmatrix", "]"}], "]"}], " ", ".", " ",
                "Mmatrix", " ", ".", " ", 
               RowBox[{"Kernel", "[", 
                RowBox[{"Length", "[", 
                 RowBox[{"Mmatrix", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}]}]}], ";", 
            "\n", "\n", 
            RowBox[{"Holes\[LetterSpace]removeFirstLastZero", "=", 
             RowBox[{"Delete", "[", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{
                 RowBox[{"Cartan", "[", 
                  RowBox[{"Length", "[", "Mmatrix", "]"}], "]"}], " ", ".", 
                 " ", "Mmatrix", " ", ".", " ", 
                 RowBox[{"Kernel", "[", 
                  RowBox[{"Length", "[", 
                   RowBox[{"Mmatrix", "[", 
