                  RowBox[{"-", "1"}], "}"}]}], "}"}]}], "]"}]}], ";", "\n", 
            RowBox[{"M\[LetterSpace]removeFirstLastZero", "=", 
             RowBox[{"Delete", "[", 
              RowBox[{
               RowBox[{"Mmatrix", "/.", 
