 RowBox[{
  RowBox[{
   RowBox[{"AugmentedYoungD", "[", "shape_", "]"}], " ", ":=", " ", "\n", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"FilledYoungD", ",", " ", "augmented"}], "}"}], ",", "\n", 
