 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"loaddata", "[", 
    RowBox[{"yd_", ",", " ", "rigg_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", "filename", "}"}], ",", "\n", "  ", "\n", "  ", 
     RowBox[{
      RowBox[{"filename", " ", "=", " ", 
       RowBox[{"\"\<\>\"", " ", "<>", " ", 
