    "\n", " ", 
   RowBox[{
    RowBox[{"Total", "[", "shape", "]"}], " ", "-", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"shape", "[", 
       RowBox[{"[", "b", "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"b", ",", " ", "1", ",", " ", "a"}], "}"}]}], "]"}], " ", "-", 
