      RowBox[{"{", 
       RowBox[{"t", ",", " ", "1", ",", " ", "s"}], "}"}]}], "]"}], " ", "+", 
    " ", 
    RowBox[{"a", "*", "s"}]}]}], " ", "\n", 
  RowBox[{"(*", 
