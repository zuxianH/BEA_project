   3.782915599600492*^9, 3.782915599891234*^9}, 3.7829159534752197`*^9, {
   3.78291599482402*^9, 3.7829160116913013`*^9}, 3.78291605514604*^9, {
   3.7829162010204363`*^9, 3.782916201198488*^9}, {3.782918277519609*^9, 
   3.782918278084437*^9}, {3.7829198767549973`*^9, 3.782919878790598*^9}, {
   3.782921361616787*^9, 3.7829213627801332`*^9}, {3.782921409814686*^9, 
   3.78292141119061*^9}, 3.782921837214797*^9, 3.7829219020125237`*^9, 
   3.782922385359808*^9, 3.782922432395481*^9, 3.7829224785151787`*^9, {
   3.782922536061616*^9, 3.782922563217079*^9}, {3.789613033959437*^9, 
