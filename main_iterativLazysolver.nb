         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
        RowBox[{"10", "^", 
         RowBox[{"-", "5"}]}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Round", " ", "Bethe", " ", "roots", " ", "to", " ", "5", " ", 
       "decimal", " ", "places"}], " ", "*)"}], "\n", 
     RowBox[{"tallyBetheRoots", " ", "=", " ", 
      RowBox[{"Tally", "[", "roundedBetheRoots", "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Count", " ", "occurrences", " ", "of", " ", "each", " ", "rounded", 
       " ", "root"}], " ", "*)"}], "\n", 
     RowBox[{"rootMultiplicity", " ", "=", " ", 
      RowBox[{"tallyBetheRoots", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Extract", " ", "multiplicities"}], " ", "*)"}], "\n", 
     RowBox[{"duplicatePositions", " ", "=", " ", "\n", "  ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Position", "[", 
        RowBox[{"rootMultiplicity", ",", " ", 
         RowBox[{"x_", " ", "/;", " ", 
          RowBox[{"x", " ", "!=", " ", "1"}]}]}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
