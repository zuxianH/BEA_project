Cell[BoxData[
 RowBox[{
  RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "roundedBetheRoots", "\[IndentingNewLine]", ",", "tallyBetheRoots", ",", 
