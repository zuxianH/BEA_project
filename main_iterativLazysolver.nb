              RowBox[{"\[CapitalLambda]Last", ">", "\[CapitalLambda]target"}],
               ",", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"step", "<", 
                  RowBox[{"10", "^", 
                   RowBox[{"-", "10"}]}]}], ",", 
                 RowBox[{"Throw", "[", "\"\<step goes to zero\>\"", "]"}]}], 
                "]"}], ";", "\[IndentingNewLine]", 
               RowBox[{"\[CapitalLambda]new", "=", 
                RowBox[{"Max", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalLambda]Last", "-", "step"}], ",", 
                  "\[CapitalLambda]target"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
