   3.7829124713657417`*^9, 3.782912471990965*^9}, 3.782912623892571*^9, 
   3.782914535444984*^9, 3.7829146130066557`*^9, {3.782914809947891*^9, 
   3.7829148100881453`*^9}, {3.782915161210181*^9, 3.7829151649481487`*^9}, {
   3.782915264674835*^9, 3.782915266405148*^9}, {3.782915365677462*^9, 
