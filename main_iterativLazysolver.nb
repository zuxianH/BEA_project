  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Msetmatrix", "[", "yd_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Ms", ",", "Mmatrices", ",", "UpdMmatrices", ",", "M"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Ms", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"First", "/@", 
          RowBox[{"AugmentedYoungD", "[", "yd", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mmatrices", "=", 
       RowBox[{"PadRight", "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{"Replace", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"x__", ",", 
                RowBox[{"0", ".."}]}], "}"}], "->", 
              RowBox[{"{", "x", "}"}]}], "]"}], ",", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Solve", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Sum", "[", 
                   RowBox[{
                    RowBox[{"s", "*", 
                    RowBox[{"M", "[", "s", "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"s", ",", "1", ",", "\[Lambda]"}], "}"}]}], "]"}],
                   "==", "\[Lambda]"}], ",", 
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"M", "[", "t", "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"t", ",", "1", ",", "\[Lambda]"}], "}"}]}], "]"}],
                  ",", "NonNegativeIntegers"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"\[Lambda]", ",", "Ms"}], "}"}]}], "]"}], "//", 
             "Values"}], " ", ",", 
            RowBox[{"{", "2", "}"}]}], "]"}], "//", "Tuples"}], ")"}]}]}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"All", " ", "possible", " ", "Ms", " ", "sets"}], ";", 
        RowBox[{
        "the", " ", "index", " ", "is", " ", "the", " ", "string", " ", 
         "length", " ", "and", " ", "the", " ", "value", " ", "is", " ", 
         "the", " ", "number", " ", "of", " ", "strings", " ", "of", " ", 
         "that", " ", "length"}]}], "*)"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
          RowBox[{
           RowBox[{"UpdMmatrices", "=", "matrix"}], " ", ";", 
           "\[IndentingNewLine]", 
           RowBox[{
           "Append", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Prepend", "[", 
              RowBox[{"UpdMmatrices", ",", 
               RowBox[{"SparseArray", "[", 
                RowBox[{
                 RowBox[{"1", "->", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"AugmentedYoungD", "[", "yd", "]"}], "//", 
                    "First"}], "//", "First"}], ")"}]}], ",", 
                 RowBox[{"Length", "[", 
                  RowBox[{"UpdMmatrices", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], "]"}], 
             ",", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"Length", "[", 
                RowBox[{"UpdMmatrices", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], "]"}]}]}], 
         "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"matrix", ",", "Mmatrices"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
