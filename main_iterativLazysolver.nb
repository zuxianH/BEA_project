   RowBox[{"(*", " ", 
    RowBox[{"Path", " ", "\[LeftRightArrow]", " ", "Tableaux"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToCrystalPath", "[", "stb_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"stb", "//", "Flatten"}], "]"}]}], "}"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"stb", ",", "k"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "}"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "len"}], "}"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToTableau", "[", "path_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"pr", "=", 
          RowBox[{"path", "//", "Flatten"}]}], ",", "max"}], "}"}], ",", 
       RowBox[{
        RowBox[{"max", "=", 
         RowBox[{"Max", "[", "pr", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Position", "[", 
            RowBox[{"pr", ",", "k"}], "]"}], "//", "Flatten"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "max"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Quiet", "[", 
     RowBox[{"Needs", "[", "\"\<Combinatorica`\>\"", "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Generating", " ", "rigged"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToRigged", "[", 
      RowBox[{"SYT_", ",", 
       RowBox[{"n_", ":", "5"}]}], "]"}], ":=", 
     RowBox[{"rkkrec", "[", 
      RowBox[{
       RowBox[{"ToCrystalPath", "[", "SYT", "]"}], ",", "n"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
