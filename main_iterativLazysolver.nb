              " ", "*)"}], "\n", "        ", 
             RowBox[{"{", 
              RowBox[{"epsilon", ",", " ", "initialGuesses"}], "}"}]}]}], 
           "\n", "      ", "]"}], ",", "\n", "      ", 
          RowBox[{"{", 
           RowBox[{"eps", ",", " ", "epsilonList"}], "}"}]}], "\n", "    ", 
         "]"}]}], ";", "\n", "    ", "\n", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{"Extract", " ", "results"}], " ", "*)"}], "\n", "    ", 
