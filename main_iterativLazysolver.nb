Cell["Generating list of subleading equations and solving them.", "Text",
 CellChangeTimes->{{3.7896277006802263`*^9, 3.789627726074938*^9}, {
  3.789627913025038*^9, 3.789627932807118*^9}, {3.789628087576496*^9, 
  3.789628118916696*^9}, {3.789628748806629*^9, 3.789628753954692*^9}, {
