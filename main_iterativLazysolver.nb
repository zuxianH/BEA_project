Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BAElog", "[", 
    RowBox[{
    "k_", ",", "a_", ",", "s_", ",", "modenumber_", ",", "modes_", ",", 
     "epsilon_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"modenumber", "-", 
     RowBox[{"epsilon", " ", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"sss", "=", "1"}], 
        RowBox[{"Length", "[", 
         RowBox[{
         "modes", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
         "]"}]], 
       RowBox[{"(", 
        RowBox[{
         UnderoverscriptBox["\[Sum]", 
          RowBox[{"jjj", "=", "1"}], 
          RowBox[{"Length", "[", 
           RowBox[{"modes", "\[LeftDoubleBracket]", 
            RowBox[{"a", ",", "sss"}], "\[RightDoubleBracket]"}], "]"}]], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"sss", ",", "jjj"}], "}"}], "\[NotEqual]", 
            RowBox[{"{", 
             RowBox[{"s", ",", "k"}], "}"}]}], ",", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"s", "\[NotEqual]", "sss"}], ",", 
              RowBox[{"Fsym", "[", 
               RowBox[{
                FractionBox[
                 RowBox[{"2", " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"v", "[", 
                    RowBox[{"k", ",", "a", ",", "s"}], "]"}], "-", 
                    RowBox[{"v", "[", 
                    RowBox[{"jjj", ",", "a", ",", "sss"}], "]"}]}], ")"}]}], 
                 RowBox[{"s", "-", "sss"}]], ",", 
                RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", "0"}], "]"}], "+", 
            RowBox[{"Fsym", "[", 
             RowBox[{
              FractionBox[
               RowBox[{"2", " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"v", "[", 
                   RowBox[{"k", ",", "a", ",", "s"}], "]"}], "-", 
                  RowBox[{"v", "[", 
                   RowBox[{"jjj", ",", "a", ",", "sss"}], "]"}]}], ")"}]}], 
               RowBox[{"s", "+", "sss"}]], ",", 
              RowBox[{"-", "1"}], ",", "0"}], "]"}], "+", 
            RowBox[{"2", " ", 
             RowBox[{
              UnderoverscriptBox["\[Sum]", 
               RowBox[{"nnn", "=", 
                RowBox[{
                 FractionBox[
                  RowBox[{"s", "-", "sss"}], "2"], "+", "1"}]}], 
               RowBox[{
                FractionBox[
                 RowBox[{"s", "+", "sss"}], "2"], "-", "1"}]], 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"nnn", "\[NotEqual]", "0"}], ",", 
                RowBox[{"Fsym", "[", 
                 RowBox[{
                  FractionBox[
                   RowBox[{
                    RowBox[{"v", "[", 
                    RowBox[{"k", ",", "a", ",", "s"}], "]"}], "-", 
                    RowBox[{"v", "[", 
                    RowBox[{"jjj", ",", "a", ",", "sss"}], "]"}]}], "nnn"], 
                  ",", 
                  RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", "0"}], 
               "]"}]}]}]}], ",", "0"}], "]"}]}], ")"}]}]}]}], "\[Equal]", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"a", "\[Equal]", "1"}], ",", 
        RowBox[{"L", " ", 
         RowBox[{"Fsym", "[", 
          RowBox[{
           FractionBox[
            RowBox[{"2", " ", 
             RowBox[{"v", "[", 
              RowBox[{"k", ",", "a", ",", "s"}], "]"}]}], "s"], ",", 
           RowBox[{"-", "1"}], ",", "0"}], "]"}]}], ",", 
        RowBox[{
         UnderoverscriptBox["\[Sum]", 
          RowBox[{"ss", "=", "1"}], 
          RowBox[{"Length", "[", 
           RowBox[{
           "modes", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
           "]"}]], 
         RowBox[{"(", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"jj", "=", "1"}], 
            RowBox[{"Length", "[", 
             RowBox[{"modes", "\[LeftDoubleBracket]", 
              RowBox[{
               RowBox[{"a", "-", "1"}], ",", "ss"}], 
              "\[RightDoubleBracket]"}], "]"}]], 
           RowBox[{"(", 
            RowBox[{
             UnderoverscriptBox["\[Sum]", 
              RowBox[{"nn", "=", 
               RowBox[{
                FractionBox[
                 RowBox[{"s", "-", "ss"}], "2"], "+", 
                FractionBox["1", "2"]}]}], 
              RowBox[{
               FractionBox[
                RowBox[{"s", "+", "ss"}], "2"], "-", 
               FractionBox["1", "2"]}]], 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"nn", "\[NotEqual]", "0"}], ",", 
               RowBox[{"Fsym", "[", 
                RowBox[{
                 FractionBox[
                  RowBox[{
                   RowBox[{"v", "[", 
                    RowBox[{"k", ",", "a", ",", "s"}], "]"}], "-", 
                   RowBox[{"v", "[", 
                    RowBox[{"jj", ",", 
                    RowBox[{"a", "-", "1"}], ",", "ss"}], "]"}]}], "nn"], ",", 
                 RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", "0"}], "]"}]}], 
            ")"}]}], ")"}]}]}], "]"}]}], "-", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"a", "\[Equal]", 
        RowBox[{"Length", "[", "modes", "]"}]}], ",", "0", ",", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
         RowBox[{"ssss", "=", "1"}], 
         RowBox[{"Length", "[", 
          RowBox[{
          "modes", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
          "]"}]], 
        RowBox[{"(", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"jjjj", "=", "1"}], 
           RowBox[{"Length", "[", 
            RowBox[{"modes", "\[LeftDoubleBracket]", 
             RowBox[{
              RowBox[{"a", "+", "1"}], ",", "ssss"}], 
             "\[RightDoubleBracket]"}], "]"}]], 
          RowBox[{"(", 
           RowBox[{
            UnderoverscriptBox["\[Sum]", 
             RowBox[{"nnnn", "=", 
              RowBox[{
               FractionBox[
                RowBox[{"s", "-", "ssss"}], "2"], "+", 
               FractionBox["1", "2"]}]}], 
             RowBox[{
              FractionBox[
               RowBox[{"s", "+", "ssss"}], "2"], "-", 
              FractionBox["1", "2"]}]], 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"nnnn", "\[NotEqual]", "0"}], ",", 
              RowBox[{"Fsym", "[", 
               RowBox[{
                FractionBox[
                 RowBox[{
                  RowBox[{"v", "[", 
                   RowBox[{"k", ",", "a", ",", "s"}], "]"}], "-", 
                  RowBox[{"v", "[", 
                   RowBox[{"jjjj", ",", 
                    RowBox[{"a", "+", "1"}], ",", "ssss"}], "]"}]}], "nnnn"], 
                ",", 
                RowBox[{"-", "1"}], ",", "0"}], "]"}], ",", "0"}], "]"}]}], 
           ")"}]}], ")"}]}]}], "]"}]}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rootfinder", "[", 
     RowBox[{"modes_", ",", "startvalues_", ",", "epsilon_"}], "]"}], ":=", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"BAElog", "[", 
          RowBox[{"k", ",", "a", ",", "s", ",", 
           RowBox[{"modes", "[", 
            RowBox[{"[", 
             RowBox[{"a", ",", "s", ",", "k"}], "]"}], "]"}], ",", "modes", 
           ",", "epsilon"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", "1", ",", 
           RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", "1", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"modes", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"modes", "[", 
             RowBox[{"[", 
              RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
       "//", "Flatten"}], ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"v", "[", 
             RowBox[{"k", ",", "a", ",", "s"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"a", ",", "1", ",", 
              RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"s", ",", "1", ",", 
              RowBox[{"Length", "[", 
               RowBox[{"modes", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", 
              RowBox[{"Length", "[", 
               RowBox[{"modes", "[", 
                RowBox[{"[", 
                 RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "}"}]}], 
           "]"}], "//", "Flatten"}], ",", "\[IndentingNewLine]", 
         "startvalues"}], "}"}], "//", "Transpose"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"uZeoroEpsilon", "[", 
   RowBox[{"k_", ",", "a_", ",", "s_", ",", "modes_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Tan", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"modes", "[", 
       RowBox[{"[", 
        RowBox[{"a", ",", "s", ",", "k"}], "]"}], "]"}]}], "*", 
     RowBox[{"Pi", "/", "L"}]}], "]"}], "*", 
   RowBox[{"s", "/", "2"}]}]}]}], "Input",
 InitializationCell->True,
