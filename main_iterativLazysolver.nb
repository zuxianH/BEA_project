Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"showSYT", "[", "\[Lambda]T_", "]"}], " ", ":=", " ", 
    RowBox[{"Graphics", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"\[Lambda]T", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "s"}], "]"}], "]"}], ",", " ", "Small", ",",
               " ", "Black"}], "]"}], ",", " ", "\n", "       ", 
            RowBox[{"{", 
             RowBox[{"s", ",", " ", 
              RowBox[{"-", "a"}]}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"Opacity", "[", "0.5", "]"}], ",", " ", 
          RowBox[{"Lighter", "[", 
           RowBox[{"Lighter", "[", "Gray", "]"}], "]"}], ",", " ", "\n", 
          "      ", 
          RowBox[{"Rectangle", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"s", " ", "-", " ", 
              RowBox[{"1", "/", "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"-", "a"}], " ", "-", " ", 
              RowBox[{"1", "/", "2"}]}]}], "}"}], "]"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"a", ",", " ", "1", ",", " ", 
          RowBox[{"Length", "[", "\[Lambda]T", "]"}]}], "}"}], ",", " ", "\n",
         "     ", 
        RowBox[{"{", 
         RowBox[{"s", ",", " ", "1", ",", " ", 
          RowBox[{"Length", "[", 
           RowBox[{"\[Lambda]T", "[", 
            RowBox[{"[", "a", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", " ", 
      RowBox[{"ImageSize", " ", "->", " ", "Tiny"}]}], "]"}]}], ";"}], " ", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Next", " ", "command", " ", "includes", " ", "domain", " ", "of", " ", 
    "interest"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"showSYT", "[", 
     RowBox[{"\[Lambda]T_", ",", "\"\<DOI\>\""}], "]"}], ":=", 
    RowBox[{"Graphics", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"\[Lambda]T", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "s"}], "]"}], "]"}], ",", " ", "Small", ",",
               " ", "Black"}], "]"}], ",", " ", "\n", "       ", 
            RowBox[{"{", 
             RowBox[{"s", ",", " ", 
              RowBox[{"-", "a"}]}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"Opacity", "[", "0.5", "]"}], ",", " ", 
          RowBox[{"Lighter", "[", 
           RowBox[{"Lighter", "[", "Gray", "]"}], "]"}], ",", " ", "\n", 
          "      ", 
          RowBox[{"Rectangle", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"s", " ", "-", " ", 
              RowBox[{"1", "/", "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"-", "a"}], " ", "-", " ", 
              RowBox[{"1", "/", "2"}]}]}], "}"}], "]"}], ",", " ", "\n", 
          "      ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"MemberQ", "[", 
             RowBox[{"DomainOfInterest", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"a", " ", "-", " ", "1"}], ",", " ", 
                RowBox[{"s", " ", "-", " ", "1"}]}], "}"}]}], "]"}], ",", " ",
             "\n", "       ", 
            RowBox[{"{", 
             RowBox[{"Gray", ",", " ", 
              RowBox[{"Rectangle", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"s", " ", "-", " ", 
                  RowBox[{"1", "/", "2"}]}], ",", " ", 
                 RowBox[{
                  RowBox[{"-", "a"}], " ", "-", " ", 
                  RowBox[{"1", "/", "2"}]}]}], "}"}], "]"}]}], "}"}], ",", 
            " ", "\n", "       ", "Nothing"}], "]"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"a", ",", " ", "1", ",", " ", 
          RowBox[{"Length", "[", "\[Lambda]T", "]"}]}], "}"}], ",", " ", "\n",
         "     ", 
        RowBox[{"{", 
         RowBox[{"s", ",", " ", "1", ",", " ", 
          RowBox[{"Length", "[", 
           RowBox[{"\[Lambda]T", "[", 
            RowBox[{"[", "a", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", " ", 
      RowBox[{"ImageSize", " ", "->", " ", "Tiny"}]}], "]"}]}], ";"}], 
  " "}]}], "Input",
 InitializationCell->True,
