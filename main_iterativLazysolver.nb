Cell[BoxData[
 RowBox[{
  RowBox[{"urootsStringHypothesisSUN", "[", 
   RowBox[{
   "L_", ",", "modes_", ",", "\[Epsilon]Start_", ",", "\[Epsilon]Steps_"}], 
   "]"}], ":=", 
  RowBox[{"(*", 
   RowBox[{"MAIN", " ", 
    RowBox[{"FUNCTION", ".", " ", "Produces"}], " ", "a", " ", "list", " ", 
    "of", " ", "the", " ", 
    RowBox[{"uroots", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Epsilon]list", ",", "ustart", ",", "solutions", ",", "finalvalue", 
      ",", "Ma", ",", "Mas"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Epsilon]list", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"\[Epsilon]Start", ",", "1", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Epsilon]Start"}], ")"}], "/", 
         "\[Epsilon]Steps"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "The", " ", "list", " ", "of", " ", "epislon", " ", "values", " ", "to",
        " ", "iterate", " ", "over"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"ustart", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"uZeoroEpsilon", "[", 
          RowBox[{"k", ",", "a", ",", "s", ",", "modes"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", "1", ",", 
           RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", "1", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"modes", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"modes", "[", 
             RowBox[{"[", 
              RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
       "//", "Flatten"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"finalvalue", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"solutions", "=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "startvalues", "}"}], ",", 
