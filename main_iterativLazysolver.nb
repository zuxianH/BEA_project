Cell[BoxData[{
 RowBox[{
  RowBox[{"lazyroots", "=", 
   RowBox[{"Replace", "[", 
    RowBox[{
     RowBox[{"Map", "[", 
      RowBox[{"Flatten", ",", 
       RowBox[{
        RowBox[{"iterativLazysolver", "[", 
