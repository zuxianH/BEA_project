           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"modes", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "}"}]}], 
          "]"}], "//", "Flatten"}]}], ";", "\n", "    ", "\n", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Parallel", " ", "computation", " ", "for", " ", "solving", " ", 
         "BAE", " ", "at", " ", "each", " ", "epsilon"}], " ", "*)"}], "\n", 
       "    ", 
       RowBox[{"parallelResults", " ", "=", " ", 
        RowBox[{"ParallelTable", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"epsilon", ",", " ", "solution"}], "}"}], ",", "\n", 
            "        ", 
            RowBox[{
             RowBox[{"epsilon", " ", "=", " ", "eps"}], ";", "\n", "        ", 
             RowBox[{"solution", " ", "=", " ", 
              RowBox[{
               RowBox[{"rootfinder", "[", 
