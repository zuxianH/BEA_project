 RowBox[{
  RowBox[{"Cartan", "[", "a_", "]"}], ":=", 
  RowBox[{"SparseArray", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], "]"}], "->", "2"}], ",", 
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"2", ",", "1"}], "}"}], "]"}], "->", 
       RowBox[{"-", "1"}]}], ",", 
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], "]"}], "->", 
       RowBox[{"-", "1"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"a", ",", "a"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Kernel", "[", "s_", "]"}], ":=", 
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Min", "[", 
       RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "s"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Code", " ", "taking", " ", "a", " ", "Young", " ", "diagram", " ", "and", 
    " ", "producing", " ", "all", " ", "admissible", " ", "string", " ", 
    "length", " ", "collections", " ", "and", " ", "the", " ", "bounds", " ", 
    "on", " ", "the", " ", "mode", " ", "numbers", " ", "for", " ", 
    RowBox[{"these", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TransposeYoungD", "[", "shape_", "]"}], " ", ":=", " ", "\n", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"Select", "[", 
       RowBox[{"shape", ",", " ", 
        RowBox[{
         RowBox[{"#", " ", ">", " ", "i"}], " ", "&"}]}], "]"}], "]"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "0", ",", " ", "\n", " ", " ", " ", 
       RowBox[{
        RowBox[{"shape", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", "1"}]}], "}"}]}], 
    "]"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Populating", " ", "the", " ", "Transpose", " ", "diagram"}], ";",
     " ", 
    RowBox[{"using", " ", 
     RowBox[{"Volin", "'"}], "s", " ", "code"}]}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"MAS", "[", 
    RowBox[{"a_", ",", " ", "s_", ",", " ", "shape_"}], "]"}], " ", ":=", " ",
    "\n", " ", 
   RowBox[{
    RowBox[{"Total", "[", "shape", "]"}], " ", "-", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"shape", "[", 
       RowBox[{"[", "b", "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"b", ",", " ", "1", ",", " ", "a"}], "}"}]}], "]"}], " ", "-", 
    " ", "\n", " ", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"TransposeYoungD", "[", "shape", "]"}], "[", 
       RowBox[{"[", "t", "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "1", ",", " ", "s"}], "}"}]}], "]"}], " ", "+", 
    " ", 
    RowBox[{"a", "*", "s"}]}]}], " ", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Function", " ", "M_as", " ", "used", " ", "in", " ", "article"}], 
   "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AugmentedYoungD", "[", "shape_", "]"}], " ", ":=", " ", "\n", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"FilledYoungD", ",", " ", "augmented"}], "}"}], ",", "\n", " ", 
     " ", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"augmented", " ", "=", " ", "\n", " ", " ", " ", 
        RowBox[{
         RowBox[{"Prepend", "[", 
          RowBox[{"shape", ",", " ", 
           RowBox[{"shape", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}], " ", "+", " ", "\n", " ",
          " ", " ", " ", "1"}]}], 
       RowBox[{"(*", 
        RowBox[{
        "Creating", " ", "a", " ", "set", " ", "of", " ", "right", " ", 
         "size", " ", "for", " ", "finding", " ", "all", " ", "MAS", " ", 
         "values"}], "*)"}], ";", "\n", " ", " ", 
       RowBox[{"FilledYoungD", " ", "=", " ", "\n", " ", " ", " ", 
        RowBox[{"Table", "[", 
