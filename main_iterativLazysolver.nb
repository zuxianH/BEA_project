Cell["\<\
Generating system of relations with leading coefficient plugged in. Working \
only up to maxord (I think I overdo one order)\
\>", "Text",
 CellChangeTimes->{{3.7896279693267508`*^9, 3.7896279820471773`*^9}, {
  3.789634107814488*^9, 
  3.789634121156204*^9}},ExpressionUUID->"f94b2ff7-4fc0-4077-850c-\
e1a0501365fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Large\[CapitalLambda]Expansion", ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
         "mPrint", "[", 
          "\"\<1/\[CapitalLambda] expansion of QQ system around the chosen \
SYT solution...\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"showSYT", "[", "\[Lambda]T", "]"}], "//", "mPrint"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[CapitalLambda]init\[Theta]rep", "=", 
          RowBox[{
           RowBox[{"init\[Theta]rep", "[", "\[Lambda]T", "]"}], "/.", 
           RowBox[{
            RowBox[{"\[Theta]", "[", "i_", "]"}], "\[RuleDelayed]", 
            SuperscriptBox["\[CapitalLambda]", "i"]}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"fsymrep", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
             RowBox[{"Expand", "@", 
              RowBox[{"Coefficient", "[", 
               RowBox[{
                RowBox[{"Product", "[", 
                 RowBox[{
                  RowBox[{"u", "-", 
                   SuperscriptBox["\[CapitalLambda]", "i"]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "Len"}], "}"}]}], "]"}], ",", "u", ",", 
                RowBox[{"Len", "-", "n"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"finit\[Theta]rep", "=", "\[CapitalLambda]init\[Theta]rep"}],
          ";", 
         RowBox[{"(*", " ", 
          RowBox[{
          "definition", " ", "for", " ", "forward", " ", "compatibility"}], 
          " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"ftransit", "=", 
          RowBox[{
           RowBox[{"Solve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"a", "+", "s"}], "\[Equal]", "0"}], "||", 
                    RowBox[{"Not", "@", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"vars2", ",", 
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "1"}], "]"}]}], "]"}]}]}], 
                    ",", "Nothing", ",", 
                    RowBox[{"CoefficientList", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"YQa", "[", 
                    RowBox[{"a", ",", "s"}], "]"}], "-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"YQ\[Theta]", "[", 
                    RowBox[{"a", ",", "s"}], "]"}], "/.", 
                    "\[CapitalLambda]init\[Theta]rep"}], ")"}]}], ",", "u"}], 
                    "]"}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"a", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
                   "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"s", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"\[Lambda]", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], 
                   "}"}]}], "]"}], "//", "Flatten"}], ")"}], "\[Equal]", 
              "0"}], ",", "vars2"}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"\[CapitalLambda]transit", "=", 
          RowBox[{"Thread", "[", 
           RowBox[{"Rule", "[", 
            RowBox[{
             RowBox[{"ftransit", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#", "/.", 
                 RowBox[{
                  SuperscriptBox["\[CapitalLambda]", 
                   RowBox[{"pow_", "/;", 
                    RowBox[{"pow", "<", 
                    RowBox[{
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}], "-", 
                    "maxord"}]}]}]], "\[RuleDelayed]", "0"}]}], ")"}], "&"}], 
              "/@", 
              RowBox[{"ftransit", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], "]"}], "]"}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "choosing", " ", "special", " ", "parameterisation", " ", "of", " ",
            "inhomogeneities"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"symrep", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
              RowBox[{"Expand", "@", 
               RowBox[{"Coefficient", "[", 
                RowBox[{
                 RowBox[{"Product", "[", 
                  RowBox[{
                   RowBox[{"u", "-", 
                    SuperscriptBox["\[CapitalLambda]", "i"]}], ",", 
                   RowBox[{"{", 
                    RowBox[{"i", ",", "Len"}], "}"}]}], "]"}], ",", "u", ",", 
                 
                 RowBox[{"Len", "-", "n"}]}], "]"}]}]}], "/.", 
             RowBox[{
              SuperscriptBox["\[CapitalLambda]", 
               RowBox[{"pow_", "/;", 
                RowBox[{"pow", "<", " ", 
                 RowBox[{
                  RowBox[{
                   FractionBox["n", "2"], 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}]}], "-", 
                  "maxord"}]}]}]], "\[RuleDelayed]", "0"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"anlytic", "=", 
          RowBox[{"Collect", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Allrel", "/.", "symrep"}], "/.", 
                RowBox[{
                 RowBox[{"c", "[", 
                  RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], 
                 "\[RuleDelayed]", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    FractionBox[
                    RowBox[{"ecc", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
                    "\[CapitalLambda]"]}], ")"}], 
                  RowBox[{"c", "[", 
                   RowBox[{"a", ",", "s", ",", "k"}], "]"}]}]}]}], "/.", 
               "\[CapitalLambda]transit"}], ")"}], "//", "Expand"}], ",", 
            "\[CapitalLambda]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
        ")"}], "//", "PrintDone"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Check on genereated equations: \>\"", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Exponent", "[", 
               RowBox[{"anlytic", ",", "\[CapitalLambda]"}], "]"}], "//", 
              "Min"}], ")"}], ">", "0"}], ")"}], ",", "\"\<passed\>\""}], 
         "]"}]}], "//", "mPrint"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
