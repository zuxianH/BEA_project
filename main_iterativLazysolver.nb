Cell[CellGroupData[{

Cell["Q-system on Young diagram", "Subsection",
 CellChangeTimes->{{3.7824170952613993`*^9, 3.782417100223358*^9}, {
  3.7896129425083303`*^9, 
  3.789612946959497*^9}},ExpressionUUID->"838ac180-f165-4d2c-ba6e-\
b3f0f4a97919"],

Cell["\<\
GenerateQsystem generates all QQ-relations. Input is  \[Lambda] - a Young \
diagram, you can also tinker with the code and specify Domain of interest \
(collection of {a,s} specifying which QQ-relations to take into account). The \
other code is compatible with this specification. \
\>", "Text",
 CellChangeTimes->{{3.793094630279077*^9, 
  3.7930946849674063`*^9}},ExpressionUUID->"51382e35-51af-4d14-a3af-\
4175f9f46be4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"GenerateQsystem", "[", "\[Lambda]_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
        "mPrint", "[", "\"\<Generating QQ relations on Young diagram...\>\"", 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Length", " ", "of", " ", "spin", " ", "chain"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Len", "=", 
         RowBox[{"Total", "[", "\[Lambda]", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Unprotect", "[", "M", "]"}], ";", 
        RowBox[{"ClearAll", "[", "M", "]"}], ";", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Unprotecting", " ", "because", " ", "of", " ", "conflict", " ", 
          "with", " ", "Combinatorica", " ", "package"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "domain", " ", "of", " ", "interest", " ", "is", " ", "the", " ", 
           "values", " ", "of", " ", 
           RowBox[{"{", 
            RowBox[{"a", ",", "s"}], "}"}], " ", "for", " ", "which", " ", 
           "we", " ", "are", " ", "going", " ", "to", " ", "check", " ", "QQ",
            " ", "relation", " ", "with", " ", 
           RowBox[{"Q", "[", 
            RowBox[{"a", ",", "s"}], "]"}], " ", "in", " ", "the", " ", "top",
            " ", "left", " ", "corner", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"smallest", " ", "a"}], ",", "s"}], ")"}], 
           "\[IndentingNewLine]", "FullYoungDiagram"}], " ", "-", " ", 
          RowBox[{
          "is", " ", "maximal", " ", "possible", " ", "domain", " ", "of", 
           " ", "interest"}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"FullYoungDiagram", "=", 
         RowBox[{"Block", "[", 
          RowBox[{
           RowBox[{"{", "mm", "}"}], ",", 
           RowBox[{
            RowBox[{"Flatten", "@", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"mm", "[", 
                RowBox[{"a", ",", "s"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"a", ",", "0", ",", 
                 RowBox[{
                  RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
                "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"s", ",", "0", ",", 
                 RowBox[{
                  RowBox[{"\[Lambda]", "[", 
                   RowBox[{"[", 
                    RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], 
                "}"}]}], "]"}]}], "/.", 
            RowBox[{"mm", "\[Rule]", "List"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"DomainOfInterest", "=", "FullYoungDiagram"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "comment", " ", "below", " ", "provides", " ", "some", " ", 
           "example", " ", "of", " ", "non"}], "-", 
          RowBox[{"standard", " ", "DomainOfInterest"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"DomainOfInterest", "=", 
           RowBox[{"Block", "[", 
            RowBox[{
             RowBox[{"{", "mm", "}"}], ",", 
             RowBox[{
              RowBox[{"Flatten", "@", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"mm", "[", 
                  RowBox[{"a", ",", "s"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"a", ",", "0", ",", "1"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"s", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "/.", 
              RowBox[{"mm", "\[Rule]", "List"}]}]}], "]"}]}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"a_", ",", "s_"}], "]"}], ":=", 
         RowBox[{
          RowBox[{"M", "[", 
           RowBox[{"a", ",", "s"}], "]"}], "=", 
          RowBox[{"Len", "+", 
           RowBox[{"a", " ", "s"}], "-", 
           RowBox[{"Total", "[", 
            RowBox[{"\[Lambda]", "[", 
             RowBox[{"[", 
              RowBox[{"1", ";;", "a"}], "]"}], "]"}], "]"}], "-", 
           RowBox[{"Total", "[", 
            RowBox[{
             RowBox[{"DualDiagram", "[", "\[Lambda]", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"1", ";;", "s"}], "]"}], "]"}], "]"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"YQa", "[", 
          RowBox[{"0", ",", "0"}], "]"}], ":=", 
         RowBox[{
          SuperscriptBox["u", "Len"], "+", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox["u", 
              RowBox[{"Len", "-", "k"}]], 
             RowBox[{"sym", "[", "k", "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "Len"}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"YQa", "[", 
          RowBox[{"a_", ",", "s_"}], "]"}], ":=", 
         RowBox[{
          SuperscriptBox["u", 
           RowBox[{"M", "[", 
            RowBox[{"a", ",", "s"}], "]"}]], "+", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"c", "[", 
              RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
             SuperscriptBox["u", 
              RowBox[{
               RowBox[{"M", "[", 
                RowBox[{"a", ",", "s"}], "]"}], "-", "k"}]]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"M", "[", 
               RowBox[{"a", ",", "s"}], "]"}]}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"YQ\[Theta]", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "=", 
         RowBox[{"YQa", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"YQ\[Theta]", "[", 
          RowBox[{"a_", ",", "s_"}], "]"}], ":=", 
         RowBox[{"Product", "[", 
          RowBox[{
           RowBox[{"u", "-", 
            RowBox[{"q\[Theta]", "[", 
             RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{"M", "[", 
              RowBox[{"a", ",", "s"}], "]"}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"QQrel", "[", 
          RowBox[{"a_", ",", "s_"}], "]"}], ":=", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"CoefficientList", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"YQa", "[", 
                 RowBox[{"a", ",", "s"}], "]"}], "/.", 
                RowBox[{"u", "\[Rule]", 
                 RowBox[{"u", "+", 
                  RowBox[{"I", "/", "2"}]}]}]}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"YQa", "[", 
                 RowBox[{
                  RowBox[{"a", "+", "1"}], ",", 
                  RowBox[{"s", "+", "1"}]}], "]"}], "/.", 
                RowBox[{"u", "\[Rule]", 
                 RowBox[{"u", "-", 
                  RowBox[{"I", "/", "2"}]}]}]}], ")"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"YQa", "[", 
                 RowBox[{"a", ",", "s"}], "]"}], "/.", 
                RowBox[{"u", "\[Rule]", 
                 RowBox[{"u", "-", 
                  RowBox[{"I", "/", "2"}]}]}]}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"YQa", "[", 
                 RowBox[{
                  RowBox[{"a", "+", "1"}], ",", 
                  RowBox[{"s", "+", "1"}]}], "]"}], "/.", 
                RowBox[{"u", "\[Rule]", 
                 RowBox[{"u", "+", 
                  RowBox[{"I", "/", "2"}]}]}]}], ")"}]}], "-", 
             RowBox[{"I", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"M", "[", 
                 RowBox[{"a", ",", "s"}], "]"}], "-", 
                RowBox[{"M", "[", 
                 RowBox[{
                  RowBox[{"a", "+", "1"}], ",", 
                  RowBox[{"s", "+", "1"}]}], "]"}]}], ")"}], 
              RowBox[{"YQa", "[", 
               RowBox[{
                RowBox[{"a", "+", "1"}], ",", "s"}], "]"}], 
              RowBox[{"YQa", "[", 
               RowBox[{"a", ",", 
                RowBox[{"s", "+", "1"}]}], "]"}]}]}], ",", "u"}], "]"}], "//", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"#", "/.", 
             RowBox[{
              RowBox[{"Complex", "[", 
               RowBox[{"0", ",", "b_"}], "]"}], "\[RuleDelayed]", "b"}]}], 
            ")"}], "&"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Allrel", "=", 
         RowBox[{
          RowBox[{"Monitor", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"MemberQ", "[", 
                  RowBox[{"DomainOfInterest", ",", 
                   RowBox[{"{", 
                    RowBox[{"a", ",", "s"}], "}"}]}], "]"}], "&&", 
                 RowBox[{
                  RowBox[{"M", "[", 
                   RowBox[{"a", ",", "s"}], "]"}], ">", "0"}]}], ",", 
                RowBox[{"QQrel", "[", 
                 RowBox[{"a", ",", "s"}], "]"}], ",", "Nothing"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"a", ",", "0", ",", 
                RowBox[{
                 RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
               "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"s", ",", "0", ",", 
                RowBox[{
                 RowBox[{"\[Lambda]", "[", 
                  RowBox[{"[", 
                   RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], 
               "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"a", ",", "s"}], "}"}]}], "]"}], "//", "Flatten"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "vars", " ", "have", " ", "coefficients", " ", "of", " ", "all", 
           " ", "Q"}], "-", "functions"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"vars", "=", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"a", "+", "s"}], "\[Equal]", "0"}], ",", "Nothing", 
              ",", 
              RowBox[{"c", "[", 
               RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"a", ",", "0", ",", 
              RowBox[{
               RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], "}"}],
             ",", 
            RowBox[{"{", 
             RowBox[{"s", ",", "0", ",", 
              RowBox[{
               RowBox[{"\[Lambda]", "[", 
                RowBox[{"[", 
                 RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"M", "[", 
               RowBox[{"a", ",", "s"}], "]"}]}], "}"}]}], "]"}], "//", 
          "Flatten"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "only", " ", "those", " ", "appearing", " ", "in", " ", "domain", 
          " ", "of", " ", "interest"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"vars2", "=", 
         RowBox[{"DeleteCases", "[", 
          RowBox[{
           RowBox[{"Variables", "[", "Allrel", "]"}], ",", 
           RowBox[{"sym", "[", "_", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"mPrint", "@", 
         RowBox[{"Column", "[", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Length of spin chain: \>\"", ",", "Len"}], "}"}]}],
             ",", "\[IndentingNewLine]", 
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Number of SYT: \>\"", ",", 
               RowBox[{"mult", "[", "\[Lambda]", "]"}]}], "}"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Domain of Interest: \>\"", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"MatrixPlot", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"Mesh", "\[Rule]", "True"}]}], "]"}], "&"}], "@", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"Which", "[", 
                   RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"DomainOfInterest", ",", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "s"}], "}"}]}], "]"}], ",", "1", ",", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"FullYoungDiagram", ",", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "s"}], "}"}]}], "]"}], ",", 
                    RowBox[{"1", "/", "2"}], ",", "True", ",", "0"}], "]"}], 
                  ",", 
                  RowBox[{"{", 
                   RowBox[{"a", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
                   "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"s", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"\[Lambda]", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
                 "]"}]}]}], "}"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Number of variables: \>\"", ",", 
               RowBox[{"Length", "[", "vars2", "]"}]}], "}"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Number of equations: \>\"", ",", 
               RowBox[{"Length", "[", "Allrel", "]"}]}], "}"}]}]}], 
           "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", ")"}], "//", "PrintDone"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
