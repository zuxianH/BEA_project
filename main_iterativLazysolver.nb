        " ", "parallelResults"}], "}"}], ",", "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Generate", " ", "a", " ", "list", " ", "of", " ", "epsilon", " ", 
        "values"}], " ", "*)"}], "\n", "    ", 
      RowBox[{
       RowBox[{"epsilonList", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{
          FractionBox["1", "500"], ",", " ", "1", ",", " ", 
          "\[Epsilon]Step"}], "]"}]}], ";", "\n", "    ", "\n", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Initialize", " ", "the", " ", "first", " ", "guess", " ", "for", " ",
          "uInitial"}], " ", "*)"}], "\n", "    ", 
       RowBox[{"initialGuesses", " ", "=", " ", "\n", "     ", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"uZeoroEpsilon", "[", 
            RowBox[{"k", ",", "a", ",", "s", ",", "modes"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"a", ",", "1", ",", 
             RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
