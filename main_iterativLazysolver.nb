     "computation"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"IterativeBAEsolverPara", "[", 
     RowBox[{"L_", ",", "modes_", ",", "\[Epsilon]Step_"}], "]"}], ":=", " ", 
    "\n", "  ", 
