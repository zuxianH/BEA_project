Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"lazySolver", "[", 
    RowBox[{"yd_", ",", " ", "riggs_", ",", " ", 
     RowBox[{"maxTime_", " ", ":", " ", "40"}], ",", " ", 
     RowBox[{"maxRetries_", " ", ":", " ", "10"}]}], "]"}], " ", ":=", " ", 
   "\n", "  ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "L", ",", " ", "rigs", ",", " ", "mySYT", ",", " ", "attempt", ",", " ",
        "result", ",", " ", "paramValue"}], "}"}], ",", "\n", "    ", "\n", 
     "     ", 
     RowBox[{
      RowBox[{"paramValue", " ", "=", " ", "40"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{"Initial", " ", "value", " ", "of", " ", "parameter"}], " ", 
       "*)"}], "\n", "    ", 
      RowBox[{"L", " ", "=", " ", 
       RowBox[{"Total", "[", "yd", "]"}]}], ";", "\n", "    ", 
      RowBox[{"rigs", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ModestoRiggedConfig", "[", 
          RowBox[{"L", ",", " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
        RowBox[{"ModesConfig", "[", "yd", "]"}]}]}], ";", "\n", "    ", 
      RowBox[{"mySYT", " ", "=", " ", 
       RowBox[{"ToSYT", " ", "/@", " ", "rigs"}]}], ";", "\n", "    ", "\n", 
      "    ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Running rigged configuration: \>\"", ",", " ", "riggs"}], 
       "]"}], ";", "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Retry", " ", "loop", " ", "with", " ", "increasing", " ", "parameter",
         " ", "values"}], " ", "*)"}], "\n", "    ", 
      RowBox[{"attempt", " ", "=", " ", "0"}], ";", "\n", "    ", 
      RowBox[{"result", " ", "=", " ", "False"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Initialize", " ", "result", " ", "to", " ", "failed", " ", "state"}], 
       " ", "*)"}], "\n", "    ", "\n", "    ", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"attempt", " ", "<", " ", "maxRetries"}], " ", "&&", " ", 
         RowBox[{"result", " ", "===", " ", "False"}]}], ",", "\n", "      ", 
        "\n", "      ", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Current paramValue: \>\"", ",", " ", "paramValue"}], 
          "]"}], ";", "\n", "      ", "\n", "      ", 
         RowBox[{"parameter", "[", "paramValue", "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"Set", " ", "parameter", " ", "value"}], " ", "*)"}], "\n", 
         "      ", 
         RowBox[{"attempt", "++"}], ";", "\n", "      ", "\n", "      ", 
         RowBox[{"result", " ", "=", " ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Catch", "[", 
              RowBox[{"SolutionFromSYT", "[", 
               RowBox[{"mySYT", "[", 
                RowBox[{"[", "riggs", "]"}], "]"}], "]"}], "]"}], "===", 
             "\"\<step goes to zero\>\""}], ",", "False", ",", "True"}], 
           "]"}]}], ";", "\n", "                ", 
         RowBox[{"NotebookDelete", "[", 
          RowBox[{"Cells", "[", 
           RowBox[{"CellStyle", " ", "->", " ", "\"\<Print\>\""}], "]"}], 
          "]"}], ";", "\n", "      ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
           "If", " ", "the", " ", "result", " ", "is", " ", "successful"}], 
           ",", " ", 
           RowBox[{"exit", " ", "loop"}]}], " ", "*)"}], "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"result", " ", "=!=", " ", "False"}], ",", " ", 
           RowBox[{"Break", "[", "]"}], ",", 
           RowBox[{"paramValue", " ", "+=", " ", "20"}]}], "]"}], ";"}]}], 
       "\n", "      ", "\n", "      ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Increase", " ", "parameter", " ", "only", " ", "when", " ", 
         "SolutionFromSYT", " ", "fails"}], " ", "*)"}], "\n", "      ", "\n",
        "    ", "]"}], ";", "\n", "    ", "\n", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"If", " ", "all", " ", "attempts", " ", "failed"}], ",", " ", 
        
        RowBox[{"return", " ", "None", " ", "and", " ", "riggs"}]}], " ", 
       "*)"}], "\n", "    ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"result", " ", "===", " ", "False"}], ",", " ", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"None", ",", " ", "riggs"}], "}"}], "]"}], ",", "\n", 
        "     ", "\n", "     ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Proceed", " ", "only", " ", "if", " ", "SolutionFromSYT", " ", 
          "succeeded"}], " ", "*)"}], "\n", "     ", "\n", "   ", "\n", 
        "     ", "\n", "     ", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "allbetheQ", ",", " ", "mysol", ",", " ", "allbetherootEqns", ",", 
            " ", "solvedBetheroots", ",", " ", "\n", "       ", 
            "listCcoefficient", ",", " ", "listUmonomial", ",", " ", 
            "listUmonomialValue", ",", " ", "\n", "       ", 
            "listUmonomialCoffValue"}], "}"}], ",", "\n", "       ", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{"\"\<succeeded with prec: \>\"", " ", ",", "paramValue"}],
             "]"}], ";", "\n", "       ", 
           RowBox[{"allbetheQ", " ", "=", " ", 
            RowBox[{"{", "}"}]}], ";", "\n", "       ", 
           RowBox[{"mysol", " ", "=", " ", "\n", "         ", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"YQa", "[", 
                RowBox[{"a", ",", " ", "0"}], "]"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"a", ",", " ", 
                 RowBox[{"Length", "[", 
                  RowBox[{"\[Lambda]", " ", "-", " ", "1"}], "]"}]}], "}"}]}],
               "]"}], " ", "/.", " ", "\n", "           ", 
             RowBox[{"First", "[", 
              RowBox[{
               RowBox[{"vars2nvars", " ", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{"FindSolit", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "}"}]}], " ", "/.", " ", 
               RowBox[{"\[CapitalLambda]", " ", "->", " ", "1"}]}], "]"}]}]}],
            ";", "\n", "       ", "\n", "       ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"allbetheQ", ",", " ", "mysol"}], "]"}], ";", "\n", 
           "       ", "\n", "       ", 
           RowBox[{"allbetherootEqns", " ", "=", " ", 
            RowBox[{
             RowBox[{"Map", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"#", " ", "==", " ", "0"}], " ", "&"}], ",", " ", 
               "allbetheQ", ",", " ", 
               RowBox[{"{", "2", "}"}]}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", " ", 
               RowBox[{"1", " ", ";;", " ", "2"}]}], "]"}], "]"}]}], ";", 
           "\n", "       ", 
           RowBox[{"solvedBetheroots", " ", "=", "\n", "         ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Table", "[", "\n", "                 ", 
                RowBox[{
                 RowBox[{"Table", "[", "\n", "                   ", 
                  RowBox[{
                   RowBox[{"Solve", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"allbetherootEqns", "[", 
                    RowBox[{"[", "w", "]"}], "]"}], "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", " ", "u"}], "]"}], 
                   ",", "\n", "                   ", 
                   RowBox[{"{", 
                    RowBox[{"k", ",", " ", 
                    RowBox[{"Length", "[", 
                    RowBox[{"allbetherootEqns", "[", 
                    RowBox[{"[", "w", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
                 ",", "\n", "                 ", 
                 RowBox[{"{", 
                  RowBox[{"w", ",", " ", 
                   RowBox[{"Length", "[", "allbetherootEqns", "]"}]}], 
                  "}"}]}], "]"}], " ", "//", " ", "Values"}], ")"}], " ", "-",
              " ", "1"}]}], ";", "\n", "       ", "\n", "       ", 
           RowBox[{"listCcoefficient", " ", "=", " ", "\n", "         ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"vars2nvars", " ", "/.", " ", 
                RowBox[{"\[CapitalLambda]", " ", "->", " ", 
                 RowBox[{"\[CapitalLambda]vals", "[", 
                  RowBox[{"[", "\n", "          ", "k", "]"}], "]"}]}]}], " ",
                "/.", " ", "\n", "             ", 
               RowBox[{"sol", "[", 
                RowBox[{"\[CapitalLambda]vals", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "]"}]}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"k", ",", " ", "\n", "             ", 
                RowBox[{"Length", "[", "\[CapitalLambda]vals", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\n", "       ", "\n", "       ", 
           RowBox[{"listUmonomial", " ", "=", " ", "\n", "         ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"k", ",", " ", 
                RowBox[{"\[CapitalLambda]vals", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], ",", " ", "\n", 
                "             ", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"YQa", "[", 
                   RowBox[{"a", ",", " ", "0"}], "]"}], ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"a", ",", " ", 
                    RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], " ", "-", " ", 
                    "1"}]}], "}"}]}], "]"}]}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"k", ",", " ", "\n", "             ", 
                RowBox[{"Length", "[", "\[CapitalLambda]vals", "]"}]}], 
               "}"}]}], "]"}]}], ";", "\n", "       ", "\n", "       ", 
           RowBox[{"listUmonomialValue", " ", "=", " ", "\n", "         ", 
            RowBox[{"MapThread", "[", "\n", "           ", 
             RowBox[{"ReplaceAll", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"listUmonomial", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", " ", "3"}], "]"}], "]"}], ",", " ", 
                "listCcoefficient"}], "}"}]}], "]"}]}], ";", "\n", "       ", 
           "\n", "       ", 
           RowBox[{"listUmonomialCoffValue", " ", "=", " ", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{"listUmonomialValue", ",", " ", "u"}], "]"}]}], ";", 
           "\n", "       ", "\n", "       ", 
           RowBox[{"{", 
            RowBox[{
            "solvedBetheroots", ",", " ", "listUmonomialCoffValue", ",", " ", 
             "\[CapitalLambda]vals"}], "}"}]}]}], "\n", "       ", "]"}]}], 
       "\n", "   ", "]"}]}]}], "]"}]}], "\n"}]], "Input",
