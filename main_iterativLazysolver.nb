Cell[BoxData[
 RowBox[{
  RowBox[{"init\[Theta]rep", "[", "\[Lambda]T_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"init\[Theta]rep", "[", "\[Lambda]T", "]"}], " ", "=", " ", "\n", 
   "   ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"kk", ",", " ", "sd"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"kk", "[", 
        RowBox[{"_", ",", " ", "_"}], "]"}], " ", "=", " ", "0"}], ";", " ", 
      RowBox[{
       RowBox[{"sd", "[", "m_", "]"}], " ", ":=", " ", "\n", "      ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"#1", ",", " ", 
            RowBox[{
             RowBox[{"#1", " ", "<=", " ", "m"}], " ", "&"}]}], " ", "]"}], 
          " ", "&"}], " ", ")"}], " ", "/@", " ", "\[Lambda]T"}]}], ";", " ", 
      "\n", "     ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"CheckStandard", "[", "\[Lambda]T", "]"}], ",", " ", "\n", 
        "      ", 
        RowBox[{"Sort", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"True", " ", "||", " ", "\n", "            ", 
                 RowBox[{"MemberQ", "[", 
                  RowBox[{"DomainOfInterest", ",", " ", 
                   RowBox[{"{", 
                    RowBox[{"a2", ",", " ", "s2"}], "}"}]}], "]"}]}], ",", 
                " ", "\n", "           ", 
                RowBox[{
                 RowBox[{"q\[Theta]", "[", 
                  RowBox[{"a2", ",", " ", "s2", ",", " ", 
                   RowBox[{"++", 
                    RowBox[{"kk", "[", 
                    RowBox[{"a2", ",", " ", "s2"}], "]"}]}]}], "]"}], " ", "->",
                  " ", "\n", "            ", 
                 RowBox[{
                  RowBox[{"Product", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{
                    RowBox[{"sd", "[", 
                    RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "a3", "]"}], "]"}], "]"}], " ", "+", " ", 
                    "a", " ", "-", " ", "\n", "                ", "s", " ", 
                    "-", " ", "a3"}], ")"}], "/", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{
                    RowBox[{"sd", "[", 
                    RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}], "[", 
                    RowBox[{"[", "a3", "]"}], "]"}], "]"}], " ", "+", " ", 
                    "\n", "                ", "a", " ", "-", " ", "s", " ", 
                    "-", " ", "a3", " ", "+", " ", "1"}], ")"}]}], ",", " ", 
                    RowBox[{"{", 
                    RowBox[{"a3", ",", " ", "1", ",", " ", "a2"}], "}"}]}], 
                   "]"}], "*", "\n", "             ", 
                  RowBox[{"Product", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"DualDiagram", "[", 
                    RowBox[{"Length", " ", "/@", " ", 
                    RowBox[{"sd", "[", 
                    RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "\n", "                   ", "s"}], 
                    "]"}], "]"}], "]"}]}], "]"}], "[", 
                    RowBox[{"[", "s3", "]"}], "]"}], " ", "+", " ", "s", " ", 
                    "-", " ", "a", " ", "-", " ", "s3"}], ")"}], "/", 
                    RowBox[{"(", "\n", "                ", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"DualDiagram", "[", 
                    RowBox[{"Length", " ", "/@", " ", 
                    RowBox[{"sd", "[", 
                    RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "]"}], 
                    "[", 
                    RowBox[{"[", "\n", "                 ", "s3", "]"}], 
                    "]"}], " ", "+", " ", "s", " ", "-", " ", "a", " ", "-", 
                    " ", "s3", " ", "+", " ", "1"}], ")"}]}], ",", " ", 
                    RowBox[{"{", 
                    RowBox[{"s3", ",", " ", "1", ",", " ", "s2"}], "}"}]}], 
                   "]"}], "*", "\n", "             ", 
                  RowBox[{"\[Theta]", "[", 
                   RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}]}], ",", 
                " ", "Nothing"}], "]"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"a2", ",", " ", "0", ",", " ", 
                RowBox[{"a", " ", "-", " ", "1"}]}], "}"}], ",", " ", "\n", 
              "          ", 
              RowBox[{"{", 
               RowBox[{"s2", ",", " ", "0", ",", " ", 
                RowBox[{"s", " ", "-", " ", "1"}]}], "}"}]}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"a", ",", " ", "1", ",", " ", 
              RowBox[{"Length", "[", "\[Lambda]T", "]"}]}], "}"}], ",", " ", 
            "\n", "         ", 
            RowBox[{"{", 
             RowBox[{"s", ",", " ", "1", ",", " ", 
              RowBox[{"Length", "[", 
               RowBox[{"\[Lambda]T", "[", 
                RowBox[{"[", "a", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
          "]"}], "]"}], ",", " ", "\n", "      ", 
        RowBox[{
         RowBox[{"Print", "[", "\"\<Not standard tableau\>\"", "]"}], ";"}]}],
        " ", "]"}]}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7827545273316193`*^9, 3.7827546078869534`*^9}, {
   3.7827546446914387`*^9, 3.782754791505526*^9}, {3.782754821838017*^9, 
