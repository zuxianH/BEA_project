Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"log", "[", 
     RowBox[{"z_", ",", 
      RowBox[{"branch_", ":", "0"}], ",", 
      RowBox[{"branchcut_", ":", 
       RowBox[{"-", "Pi"}]}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Log", "[", 
      RowBox[{"Abs", "[", "z", "]"}], "]"}], "+", 
     RowBox[{"I", "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Arg", "[", 
         RowBox[{"z", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"(", 
             RowBox[{"branchcut", "+", "Pi"}], ")"}]}], "]"}]}], "]"}], "+", 
        "branchcut", "+", "Pi", "+", 
        RowBox[{"2", "Pi", "*", "branch"}]}], ")"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Some", " ", "initial", " ", 
    RowBox[{"definitions", "."}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"arg", "[", 
   RowBox[{"z_", ",", 
    RowBox[{"branch_", ":", "0"}], ",", 
    RowBox[{"branchcut_", ":", 
     RowBox[{"-", "Pi"}]}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Arg", "[", 
    RowBox[{"z", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", 
       RowBox[{"(", 
        RowBox[{"branchcut", "+", "Pi"}], ")"}]}], "]"}]}], "]"}], "+", 
   "branchcut", "+", "Pi"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"u_", ",", 
     RowBox[{"branch_", ":", "0"}], ",", 
     RowBox[{"branchcut_", ":", 
      RowBox[{"-", "Pi"}]}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "Pi", "*", "I"}], ")"}]}], ")"}], 
    RowBox[{"log", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"u", "+", "I"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"u", "-", "I"}], ")"}]}], ",", "branch", ",", "branchcut"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Fsym", "[", 
    RowBox[{"u_", ",", 
     RowBox[{"branch_", ":", "0"}], ",", 
     RowBox[{"branchcut_", ":", 
      RowBox[{"-", "Pi"}]}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{"u", ",", "branch", ",", "branchcut"}], "]"}], "-", 
    RowBox[{"1", "/", "2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Cartan", "[", "a_", "]"}], ":=", 
  RowBox[{"SparseArray", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], "]"}], "->", "2"}], ",", 
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"2", ",", "1"}], "}"}], "]"}], "->", 
       RowBox[{"-", "1"}]}], ",", 
      RowBox[{
       RowBox[{"Band", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], "]"}], "->", 
       RowBox[{"-", "1"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"a", ",", "a"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Kernel", "[", "s_", "]"}], ":=", 
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Min", "[", 
       RowBox[{"#1", ",", "#2"}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "s"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"toBetheroots", "[", "string_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "generateValuesprocessed", ",", "generateValues", ",", "processed", ",", 
      "result"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"generateValues", "[", 
       RowBox[{
        RowBox[{"v", "[", 
         RowBox[{"k_", ",", " ", "a_", ",", " ", "s_"}], "]"}], " ", "->", 
        " ", "val_"}], "]"}], " ", ":=", " ", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "shifts", "}"}], ",", "\n", "  ", 
        RowBox[{
         RowBox[{"shifts", " ", "=", " ", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"s", " ", "-", " ", "1", " ", "-", " ", 
               RowBox[{"2", " ", "j"}]}], ")"}], " ", "*", " ", "0.5", " ", 
             "I"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"j", ",", " ", "0", ",", " ", 
              RowBox[{"s", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], ";", " ",
          "\n", "  ", 
         RowBox[{"{", 
          RowBox[{"a", ",", " ", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "val"}], " ", "+", " ", "shift"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"shift", ",", " ", "shifts"}], "}"}]}], "]"}]}], 
          "}"}]}]}], "\n", "]"}]}], ";", "\n", "\n", "\n", 
     RowBox[{"processed", " ", "=", " ", 
      RowBox[{"generateValues", " ", "/@", " ", "string"}]}], ";", "\n", "\n", 
     RowBox[{"result", "=", " ", 
      RowBox[{"Values", "[", 
       RowBox[{"GroupBy", "[", 
        RowBox[{"processed", ",", " ", 
         RowBox[{"First", " ", "->", " ", "Last"}]}], "]"}], "]"}]}], ";", 
     "\n", 
     RowBox[{"Map", "[", 
      RowBox[{"Flatten", ",", "result"}], "]"}]}]}], "\n", "\n", 
   "]"}]}]}], "Input",
