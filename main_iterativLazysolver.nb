Cell[BoxData[
 RowBox[{"SubleadingOrders", ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
        "mPrint", "[", 
         "\"\<Arranging and solving 1/\[CapitalLambda] analytic equations for \
c...\>\"", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"sublead", "=", 
         RowBox[{"Monitor", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Normal", "@", 
              RowBox[{"Series", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   FractionBox["#", 
                    SuperscriptBox["\[CapitalLambda]", 
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}]]], ")"}], 
                  "&"}], "[", 
                 RowBox[{"anlytic", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                 "\[CapitalLambda]", ",", "\[Infinity]", ",", "maxord"}], 
                 "}"}]}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", 
               RowBox[{"Length", "[", "anlytic", "]"}]}], "}"}]}], "]"}], ",",
            "k"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"cutoff", "=", 
         RowBox[{
          RowBox[{"Series", "[", 
           RowBox[{"\[CapitalLambda]", ",", 
            RowBox[{"{", 
             RowBox[{"\[CapitalLambda]", ",", "\[Infinity]", ",", 
              RowBox[{"maxord", "-", "1"}]}], "}"}]}], "]"}], "-", 
          "\[CapitalLambda]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"subleadingeqns", "=", 
         RowBox[{"Monitor", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"sublead", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "/.", 
                RowBox[{
                 RowBox[{"ecc", "[", 
                  RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], 
                 "\[RuleDelayed]", 
                 RowBox[{
                  RowBox[{"Sum", "[", 
                   RowBox[{
                    FractionBox[
                    RowBox[{
                    RowBox[{"ecc", "[", "ord", "]"}], "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
                    SuperscriptBox["\[CapitalLambda]", 
                    RowBox[{"ord", "-", "1"}]]], ",", 
                    RowBox[{"{", 
                    RowBox[{"ord", ",", "1", ",", "maxord"}], "}"}]}], "]"}], 
                  "+", "cutoff"}]}]}], ")"}], "[", 
              RowBox[{"[", "3", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", 
               RowBox[{"Length", "[", "sublead", "]"}]}], "}"}]}], "]"}], ",",
            "k"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"\[CapitalLambda]sol", "[", "ord", "]"}], "=", 
           RowBox[{
            RowBox[{"Solve", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"subleadingeqns", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", "ord"}], "]"}], "]"}], "\[Equal]", 
                "0"}], "/.", 
               RowBox[{"Flatten", "@", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalLambda]sol", "[", "k", "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"k", ",", 
                    RowBox[{"ord", "-", "1"}]}], "}"}]}], "]"}]}]}], ",", 
              RowBox[{"vars2", "/.", 
               RowBox[{
                RowBox[{"c", "[", 
                 RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], 
                "\[RuleDelayed]", 
                RowBox[{
                 RowBox[{"ecc", "[", "ord", "]"}], "[", 
                 RowBox[{"a", ",", "s", ",", "k"}], "]"}]}]}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"ord", ",", "maxord"}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ";"}], ")"}], "//", "PrintDone"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.782995615791129*^9, 3.782995679963996*^9}, 
   3.7830060316768312`*^9, {3.783009061415781*^9, 3.7830090624117727`*^9}, {
   3.78962491134274*^9, 3.7896249129188757`*^9}, {3.789627692082143*^9, 
   3.7896276929221907`*^9}, {3.789627941199524*^9, 3.789627943271392*^9}, {
