Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Main", " ", "iterative", " ", "solver"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"IterativeBAEsolver", "[", 
     RowBox[{"L_", ",", "modes_", ",", "\[Epsilon]Step_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"epsilon", "=", 
         FractionBox["1", "1000"]}], ",", "solution", ",", "uInitial", ",", 
        "results"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Initialize", " ", "the", " ", "first", " ", "guess_", " ", "for", " ",
         "uInitial"}], "*)"}], 
      RowBox[{
       RowBox[{"uInitial", "=", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"uZeoroEpsilon", "[", 
            RowBox[{"k", ",", "a", ",", "s", ",", "modes"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"a", ",", "1", ",", 
             RowBox[{"Length", "[", "modes", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"s", ",", "1", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"modes", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"modes", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "}"}]}], 
          "]"}], "//", "Flatten"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"results", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"While", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"epsilon", "<=", "1"}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "Solve", " ", "for", " ", "the", " ", "current", " ", "epsilon"}], 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"solution", "=", 
           RowBox[{
            RowBox[{"rootfinder", "[", 
             RowBox[{"modes", ",", "uInitial", ",", "epsilon"}], "]"}], "//", 
            "Quiet"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"results", ",", 
            RowBox[{"{", 
             RowBox[{"epsilon", ",", "solution"}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "the", " ", "initial", " ", "guess", " ", "for", 
            " ", "the", " ", "next", " ", "iteration"}], "*)"}], 
          RowBox[{"uInitial", "=", 
           RowBox[{"solution", "//", "Values"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Increment", " ", "epsilon"}], "*)"}], 
          RowBox[{"epsilon", "+=", "\[Epsilon]Step"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"results", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}], "//", "Chop"}]}]}], "]"}]}], 
   ";"}]}]], "Input",
