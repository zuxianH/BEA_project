Cell["\<\
Generating system of relations with leading coefficient plugged in. Working \
only up to maxord (I think I overdo one order)\
\>", "Text",
 CellChangeTimes->{{3.7896279693267508`*^9, 3.7896279820471773`*^9}, {
  3.789634107814488*^9, 
  3.789634121156204*^9}},ExpressionUUID->"f94b2ff7-4fc0-4077-850c-\
e1a0501365fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Large\[CapitalLambda]Expansion", ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[CapitalLambda]init\[Theta]rep", "=", 
         RowBox[{
          RowBox[{"init\[Theta]rep", "[", "\[Lambda]T", "]"}], "/.", 
          RowBox[{
           RowBox[{"\[Theta]", "[", "i_", "]"}], "\[RuleDelayed]", 
           SuperscriptBox["\[CapitalLambda]", "i"]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"fsymrep", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
            RowBox[{"Expand", "@", 
             RowBox[{"Coefficient", "[", 
              RowBox[{
               RowBox[{"Product", "[", 
                RowBox[{
                 RowBox[{"u", "-", 
                  SuperscriptBox["\[CapitalLambda]", "i"]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", "Len"}], "}"}]}], "]"}], ",", "u", ",", 
               RowBox[{"Len", "-", "n"}]}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"finit\[Theta]rep", "=", "\[CapitalLambda]init\[Theta]rep"}], 
        ";", 
        RowBox[{"(*", " ", 
         RowBox[{
         "definition", " ", "for", " ", "forward", " ", "compatibility"}], 
         " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"ftransit", "=", 
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"a", "+", "s"}], "\[Equal]", "0"}], "||", 
                    RowBox[{"Not", "@", 
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"vars2", ",", 
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "1"}], "]"}]}], "]"}]}]}], ",",
                    "Nothing", ",", 
                   RowBox[{"CoefficientList", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"YQa", "[", 
                    RowBox[{"a", ",", "s"}], "]"}], "-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"YQ\[Theta]", "[", 
                    RowBox[{"a", ",", "s"}], "]"}], "/.", 
                    "\[CapitalLambda]init\[Theta]rep"}], ")"}]}], ",", "u"}], 
                    "]"}]}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"a", ",", "0", ",", 
                   RowBox[{
                    RowBox[{"Length", "[", "\[Lambda]", "]"}], "-", "1"}]}], 
                  "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"s", ",", "0", ",", 
                   RowBox[{
                    RowBox[{"\[Lambda]", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", "+", "1"}], "]"}], "]"}], "-", "1"}]}], 
                  "}"}]}], "]"}], "//", "Flatten"}], ")"}], "\[Equal]", "0"}],
             ",", "vars2"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"\[CapitalLambda]transit", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"Rule", "[", 
           RowBox[{
            RowBox[{"ftransit", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"#", "/.", 
                RowBox[{
                 SuperscriptBox["\[CapitalLambda]", 
                  RowBox[{"pow_", "/;", 
                   RowBox[{"pow", "<", 
                    RowBox[{
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}], "-", 
                    "maxord"}]}]}]], "\[RuleDelayed]", "0"}]}], ")"}], "&"}], 
             "/@", 
             RowBox[{"ftransit", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "choosing", " ", "special", " ", "parameterisation", " ", "of", " ", 
          "inhomogeneities"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"symrep", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
             RowBox[{"Expand", "@", 
              RowBox[{"Coefficient", "[", 
               RowBox[{
                RowBox[{"Product", "[", 
                 RowBox[{
                  RowBox[{"u", "-", 
                   SuperscriptBox["\[CapitalLambda]", "i"]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "Len"}], "}"}]}], "]"}], ",", "u", ",", 
                RowBox[{"Len", "-", "n"}]}], "]"}]}]}], "/.", 
            RowBox[{
             SuperscriptBox["\[CapitalLambda]", 
              RowBox[{"pow_", "/;", 
               RowBox[{"pow", "<", " ", 
                RowBox[{
                 RowBox[{
                  FractionBox["n", "2"], 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}]}], "-", 
                 "maxord"}]}]}]], "\[RuleDelayed]", "0"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"anlytic", "=", 
         RowBox[{"Collect", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Allrel", "/.", "symrep"}], "/.", 
               RowBox[{
                RowBox[{"c", "[", 
                 RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "+", 
                   FractionBox[
                    RowBox[{"ecc", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
                    "\[CapitalLambda]"]}], ")"}], 
                 RowBox[{"c", "[", 
                  RowBox[{"a", ",", "s", ",", "k"}], "]"}]}]}]}], "/.", 
              "\[CapitalLambda]transit"}], ")"}], "//", "Expand"}], ",", 
           "\[CapitalLambda]"}], "]"}]}], ";"}], "\[IndentingNewLine]", ")"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"\"\<Check on genereated equations: \>\"", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Exponent", "[", 
              RowBox[{"anlytic", ",", "\[CapitalLambda]"}], "]"}], "//", 
             "Min"}], ")"}], ">", "0"}], ")"}], ",", "\"\<passed\>\""}], 
        "]"}]}], ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.78963319043766*^9, 3.7896332300219517`*^9}, {
   3.789633289746232*^9, 3.789633370863493*^9}, {3.789633424388658*^9, 
   3.7896334247690077`*^9}, {3.789633616532228*^9, 3.789633666199493*^9}, {
   3.789633848955405*^9, 3.789633953549899*^9}, 3.789635060817212*^9, 
   3.789636002129383*^9, 3.789764107567519*^9, {3.789764162281044*^9, 
   3.789764181258417*^9}, {3.789764271498568*^9, 3.789764291657583*^9}, {
   3.789764325730994*^9, 3.789764333691625*^9}, 3.790486579507084*^9, {
   3.793095209777986*^9, 3.7930952696876717`*^9}, {3.79309532490126*^9, 
   3.79309534622756*^9}, {3.793099951804048*^9, 3.793099952571616*^9}, {
   3.793099995692474*^9, 3.7931000010765123`*^9}, {3.79310003453019*^9, 
   3.793100039496966*^9}, {3.793100069981718*^9, 3.7931000708027477`*^9}, {
   3.793100345515003*^9, 3.793100357959474*^9}, {3.7931043744756947`*^9, 
   3.793104415438181*^9}, {3.7931045588503723`*^9, 3.793104577631215*^9}, {
   3.7931046617599*^9, 3.793104662069702*^9}, {3.793104813397156*^9, 
   3.793104892338613*^9}, {3.793104933449995*^9, 3.7931049381232643`*^9}, {
   3.793104986518106*^9, 3.7931049923604193`*^9}, {3.793105022581352*^9, 
   3.793105024984581*^9}, {3.7931058151293373`*^9, 3.793105815420122*^9}, {
   3.7931287541673307`*^9, 3.793128761340659*^9}, 3.793150758257978*^9, {
   3.94905467715835*^9, 3.9490546888731575`*^9}, {3.9490553791960144`*^9, 
   3.94905537961273*^9}},
 CellLabel->
  "In[124]:=",ExpressionUUID->"ba31a11c-92d5-40a6-ad20-d74d92a49132"],

Cell["Generating list of subleading equations and solving them.", "Text",
 CellChangeTimes->{{3.7896277006802263`*^9, 3.789627726074938*^9}, {
  3.789627913025038*^9, 3.789627932807118*^9}, {3.789628087576496*^9, 
  3.789628118916696*^9}, {3.789628748806629*^9, 3.789628753954692*^9}, {
  3.789634166688857*^9, 3.7896341712218323`*^9}, {3.7931003050325623`*^9, 
  3.79310030721084*^9}},ExpressionUUID->"4b3cd1b2-2b5f-43c4-9b80-\
ab53f4714476"],

Cell[BoxData[
 RowBox[{"SubleadingOrders", ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"sublead", "=", 
        RowBox[{"Monitor", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Normal", "@", 
             RowBox[{"Series", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  FractionBox["#", 
                   SuperscriptBox["\[CapitalLambda]", 
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "\[CapitalLambda]"}], "]"}]]], ")"}], 
                 "&"}], "[", 
                RowBox[{"anlytic", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{
                "\[CapitalLambda]", ",", "\[Infinity]", ",", "maxord"}], 
                "}"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "anlytic", "]"}]}], "}"}]}], "]"}], ",", 
          "k"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"cutoff", "=", 
        RowBox[{
         RowBox[{"Series", "[", 
          RowBox[{"\[CapitalLambda]", ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalLambda]", ",", "\[Infinity]", ",", 
             RowBox[{"maxord", "-", "1"}]}], "}"}]}], "]"}], "-", 
         "\[CapitalLambda]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"subleadingeqns", "=", 
        RowBox[{"Monitor", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"sublead", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "/.", 
               RowBox[{
                RowBox[{"ecc", "[", 
                 RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
                RowBox[{
                 RowBox[{"Sum", "[", 
                  RowBox[{
                   FractionBox[
                    RowBox[{
                    RowBox[{"ecc", "[", "ord", "]"}], "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], 
                    SuperscriptBox["\[CapitalLambda]", 
                    RowBox[{"ord", "-", "1"}]]], ",", 
                   RowBox[{"{", 
                    RowBox[{"ord", ",", "1", ",", "maxord"}], "}"}]}], "]"}], 
                 "+", "cutoff"}]}]}], ")"}], "[", 
             RowBox[{"[", "3", "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "sublead", "]"}]}], "}"}]}], "]"}], ",", 
          "k"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[CapitalLambda]sol", "[", "ord", "]"}], "=", 
          RowBox[{
           RowBox[{"Solve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"subleadingeqns", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "ord"}], "]"}], "]"}], "\[Equal]", "0"}],
               "/.", 
              RowBox[{"Flatten", "@", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"\[CapitalLambda]sol", "[", "k", "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"ord", "-", "1"}]}], "}"}]}], "]"}]}]}], ",", 
             RowBox[{"vars2", "/.", 
              RowBox[{
               RowBox[{"c", "[", 
                RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
               RowBox[{
                RowBox[{"ecc", "[", "ord", "]"}], "[", 
                RowBox[{"a", ",", "s", ",", "k"}], "]"}]}]}]}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"ord", ",", "maxord"}], "}"}]}], "]"}], ";"}], 
      "\[IndentingNewLine]", ";"}], ")"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.782995615791129*^9, 3.782995679963996*^9}, 
   3.7830060316768312`*^9, {3.783009061415781*^9, 3.7830090624117727`*^9}, {
   3.78962491134274*^9, 3.7896249129188757`*^9}, {3.789627692082143*^9, 
   3.7896276929221907`*^9}, {3.789627941199524*^9, 3.789627943271392*^9}, {
   3.789630041060162*^9, 3.789630041755529*^9}, {3.789632533046578*^9, 
   3.7896325343602133`*^9}, {3.7931002815751534`*^9, 3.793100313993384*^9}, {
   3.793100361597324*^9, 3.793100428785564*^9}, {3.79310049931957*^9, 
   3.79310050027064*^9}, {3.793104246294186*^9, 3.793104294257783*^9}, {
   3.793104434227028*^9, 3.793104519177207*^9}, {3.79310458178398*^9, 
   3.7931045916329603`*^9}, {3.793104665653124*^9, 3.7931046660046988`*^9}, {
   3.7931225841299257`*^9, 3.793122589568665*^9}, {3.7931229455403967`*^9, 
   3.7931229472765923`*^9}, 3.793128801183468*^9, {3.949054698404093*^9, 
   3.9490547020305862`*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"f5ac4820-d448-48cd-8eca-c3effaa822b8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numerical iterations", "Subsection",
 CellChangeTimes->{{3.782994687726842*^9, 3.782994691345057*^9}, {
  3.789669089521549*^9, 3.7896691068603697`*^9}, {3.789752026307534*^9, 
  3.7897520362561693`*^9}},ExpressionUUID->"861647d8-1844-4b47-a15b-\
eff04fa3ea9e"],

Cell[BoxData[
 RowBox[{"GenerateEqnsForNumerics", ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "normalised", " ", "variables", " ", "and", " ", "equations"}], ",", 
        " ", 
        RowBox[{
        "max", " ", "powers", " ", "of", " ", "\[CapitalLambda]", " ", "are", 
         " ", "taken", " ", "out"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nvars", "=", 
        RowBox[{"vars2", "/.", 
         RowBox[{"c", "\[Rule]", "nc"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sym2nsym", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"sym", "[", "n", "]"}], "\[Rule]", 
           RowBox[{
            SuperscriptBox["\[CapitalLambda]", 
             RowBox[{"n", 
              FractionBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}], "2"]}]], 
            RowBox[{"nsym", "[", "n", "]"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nsym2sym", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"nsym", "[", "n", "]"}], "\[Rule]", 
           RowBox[{
            SuperscriptBox["\[CapitalLambda]", 
             RowBox[{
              RowBox[{"-", "n"}], 
              FractionBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "Len"}], "-", "n", "+", "1"}], ")"}], "2"]}]], 
            RowBox[{"sym", "[", "n", "]"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "Len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vars2nvars", "=", 
        RowBox[{"Thread", "[", 
         RowBox[{"Rule", "[", 
          RowBox[{"vars2", ",", 
           RowBox[{"vars2", "/.", 
            RowBox[{
             RowBox[{"c", "[", 
              RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["\[CapitalLambda]", 
                RowBox[{"Exponent", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", 
                   "ftransit"}], ",", "\[CapitalLambda]"}], "]"}]], 
               RowBox[{"nc", "[", 
                RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], ")"}]}]}]}], 
          "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nvars2vars", "=", 
        RowBox[{"Thread", "[", 
         RowBox[{"Rule", "[", 
          RowBox[{"nvars", ",", 
           RowBox[{"vars2", "/.", 
            RowBox[{
             RowBox[{"c", "[", 
              RowBox[{"a_", ",", "s_", ",", "k_"}], "]"}], "\[RuleDelayed]", 
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["\[CapitalLambda]", 
                RowBox[{"-", 
                 RowBox[{"Exponent", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"c", "[", 
                    RowBox[{"a", ",", "s", ",", "k"}], "]"}], "/.", 
                    "ftransit"}], ",", "\[CapitalLambda]"}], "]"}]}]], 
               RowBox[{"c", "[", 
                RowBox[{"a", ",", "s", ",", "k"}], "]"}]}], ")"}]}]}]}], 
