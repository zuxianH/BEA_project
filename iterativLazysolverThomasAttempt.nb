                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}]}]}]}], 
             "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<Current \[CapitalLambda] history is: \>\"", ",", 
