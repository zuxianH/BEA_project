Cell[BoxData[{
 RowBox[{
  RowBox[{"changeHistory", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"newlazysolver", "[", "yd_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "solvedBetheroots", ",", " ", "duplicateRootPositions", ",", " ", "\n", 
      "   ", "previousDuplicateRootPositions", ",", " ", "iterationstep", ",",
       " ", "newsolutions", ",", " ", "changedPositions"}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{
     RowBox[{"OldStepIterate", "[", "]"}], ";", "\n", "  ", 
     RowBox[{"solvedBetheroots", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"lazySolver", "[", 
         RowBox[{"yd", ",", " ", "rigg", ",", "50"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"rigg", ",", " ", 
          RowBox[{"Length", "[", "rigs", "]"}]}], "}"}]}], "]"}]}], ";", "\n",
      "  ", "\n", "  ", 
     RowBox[{"duplicateRootPositions", " ", "=", " ", 
      RowBox[{
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}], "//",
        "Flatten"}]}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Original dubbel\>\"", " ", ",", 
       RowBox[{"FindDuplicateRootPositions", "[", "solvedBetheroots", "]"}]}],
       "]"}], ";", "\n", "  ", "\[IndentingNewLine]", "  ", 
     RowBox[{"iterationstep", " ", "=", " ", "7"}], ";", "\n", "\n", "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Iterate", " ", "until", " ", "there", " ", "are", " ", "no", " ", 
       "duplicate", " ", "root", " ", "positions"}], " ", "*)"}], "\n", "  ", 
     
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "duplicateRootPositions", "]"}], "!=", "0"}], ",",
        "\n", "   ", "\n", "      ", 
       RowBox[{
        RowBox[{"NewStepIterate", "[", 
         RowBox[{"0.3", ",", " ", "iterationstep"}], "]"}], ";", "\n", 
        "      ", 
        RowBox[{"iterationstep", "++"}], ";", " ", 
        RowBox[{"(*", " ", 
         RowBox[{"Increment", " ", "iteration", " ", "step"}], " ", "*)"}], 
        "\n", "\n", "      ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Solve", " ", "again", " ", "only", " ", "for", " ", "the", " ", 
          "changed", " ", "duplicate", " ", "positions"}], " ", "*)"}], "\n", 
        "      ", 
        RowBox[{"newsolutions", " ", "=", " ", 
         RowBox[{"Table", "[", "\n", "          ", 
          RowBox[{
           RowBox[{"lazySolver", "[", 
            RowBox[{"yd", ",", " ", 
             RowBox[{"duplicateRootPositions", "[", 
              RowBox[{"[", "position", "]"}], "]"}], ",", "50"}], "]"}], ",", 
