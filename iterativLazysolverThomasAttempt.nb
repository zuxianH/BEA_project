                   "\[CapitalLambda]vals", ",", "\[CapitalLambda]new"}], 
                   "]"}], ";", "\[IndentingNewLine]", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"pp", ">", "pmin"}], ",", 
                    RowBox[{
                    RowBox[{"qq", "=", 
                    RowBox[{"qq", "+", "\[CapitalDelta]q"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"qq", "\[Equal]", "base"}], ",", 
                    RowBox[{
                    RowBox[{"qq", "=", "1"}], ";", 
                    RowBox[{"pp", "=", 
                    RowBox[{"pp", "-", "1"}]}]}]}], "]"}]}]}], "]"}], ";"}]}],
                 "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
               RowBox[{"\[CapitalLambda]Last", "=", 
