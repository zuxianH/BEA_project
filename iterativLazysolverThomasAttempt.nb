                    RowBox[{"a", ",", "\n", "                   ", "s"}], 
                    "]"}], "]"}], "]"}]}], "]"}], "[", 
                    RowBox[{"[", "s3", "]"}], "]"}], " ", "+", " ", "s", " ", 
                    "-", " ", "a", " ", "-", " ", "s3"}], ")"}], "/", 
                    RowBox[{"(", "\n", "                ", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"DualDiagram", "[", 
                    RowBox[{"Length", " ", "/@", " ", 
                    RowBox[{"sd", "[", 
                    RowBox[{"\[Lambda]T", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "s"}], "]"}], "]"}], "]"}]}], "]"}], "[", 
                    RowBox[{"[", "\n", "                 ", "s3", "]"}], 
                    "]"}], " ", "+", " ", "s", " ", "-", " ", "a", " ", "-", 
                    " ", "s3", " ", "+", " ", "1"}], ")"}]}], ",", " ", 
                    RowBox[{"{", 
