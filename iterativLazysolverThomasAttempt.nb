      " ", 
     RowBox[{"(*", " ", 
      RowBox[{"Extract", " ", "duplicate", " ", "roots"}], " ", "*)"}], "\n", 
     
     RowBox[{"duplicateRootPositions", " ", "=", " ", 
      RowBox[{"Table", "[", "\n", "   ", 
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"roundedBetheRoots", ",", " ", 
          RowBox[{"duplicateRoots", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", " ", "\n", "   ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", 
          RowBox[{"Length", "[", "duplicateRoots", "]"}]}], "}"}]}], "\n", 
       "]"}]}], " ", ";", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Find", " ", "positions", " ", "of", " ", "duplicate", " ", "roots", " ",
        "in", " ", "original", " ", "list"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
