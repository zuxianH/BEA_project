                " ", "\n", "           ", 
                RowBox[{
                 RowBox[{"q\[Theta]", "[", 
                  RowBox[{"a2", ",", " ", "s2", ",", " ", 
                   RowBox[{"++", 
                    RowBox[{"kk", "[", 
                    RowBox[{"a2", ",", " ", "s2"}], "]"}]}]}], "]"}], " ", "->",
                  " ", "\n", "            ", 
                 RowBox[{
                  RowBox[{"Product", "[", 
