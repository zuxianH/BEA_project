            RowBox[{"While", "[", 
             RowBox[{
              RowBox[{"\[CapitalLambda]Last", ">", "\[CapitalLambda]target"}],
               ",", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"step", "<", 
                  RowBox[{"10", "^", 
                   RowBox[{"-", "10"}]}]}], ",", 
                 RowBox[{"Throw", "[", "\"\<step goes to zero\>\"", "]"}]}], 
