      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", 
       "duplicateRootPositions"}]}]}]}], "\[IndentingNewLine]", 
