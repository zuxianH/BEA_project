       RowBox[{"sd", "[", "m_", "]"}], " ", ":=", " ", "\n", "      ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"#1", ",", " ", 
            RowBox[{
             RowBox[{"#1", " ", "<=", " ", "m"}], " ", "&"}]}], " ", "]"}], 
          " ", "&"}], " ", ")"}], " ", "/@", " ", "\[Lambda]T"}]}], ";", " ", 
      "\n", "     ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"CheckStandard", "[", "\[Lambda]T", "]"}], ",", " ", "\n", 
        "      ", 
        RowBox[{"Sort", "[", 
         RowBox[{"Flatten", "[", 
