Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Distance", " ", "function"}], ",", " ", 
    RowBox[{"L", "^", "p"}]}], "*)"}], "\[IndentingNewLine]", 
