          RowBox[{"ans", "[", 
           RowBox[{"[", 
            RowBox[{"no2", ",", "1"}], "]"}], "]"}], ",", "#"}], "]"}], ",", 
        "2"}], "]"}], "&"}], "/@", "lambdalist"}]}]}]}]], "Input",
