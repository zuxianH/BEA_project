            RowBox[{"[", "baseposition", "]"}], "]"}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"positions", "[", 
                RowBox[{"[", 
                 RowBox[{"baseposition", "+", "1"}], "]"}], "]"}], "-", 
               RowBox[{"positions", "[", 
                RowBox[{"[", "baseposition", "]"}], "]"}]}], ")"}], "/", 
             RowBox[{"(", 
