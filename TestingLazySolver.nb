Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Finding", " ", "distances", " ", "between", " ", "solutions", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
       "for", " ", "different", " ", "rigged", " ", "configurations"}], ",", 
       " ", 
       RowBox[{"numbered", " ", "by", " ", "no1"}], ",", " ", "no2"}], ")"}], 
     " ", "for", " ", "chosen", " ", "lists", " ", "of", " ", "Lambda", " ", 
     "values"}], ";", " ", 
    RowBox[{
    "lambdalist", " ", "is", " ", "a", " ", "descending", " ", "list"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"coeffStraightlines", "[", 
     RowBox[{"positions_", ",", "lambdalist_", ",", "lambda_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"baselambda", ",", "baseposition", ",", "foundpositions"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"baselambda", "=", 
        RowBox[{"SelectFirst", "[", 
         RowBox[{
          RowBox[{"lambdalist", "//", "Reverse"}], ",", 
          RowBox[{
           RowBox[{"#", ">=", "lambda"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"baseposition", "=", 
        RowBox[{
         RowBox[{"Position", "[", 
          RowBox[{"lambdalist", ",", "baselambda"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"foundpositions", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"lambda", "!=", 
           RowBox[{"lambdalist", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"positions", "[", 
            RowBox[{"[", "baseposition", "]"}], "]"}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"positions", "[", 
                RowBox[{"[", 
                 RowBox[{"baseposition", "+", "1"}], "]"}], "]"}], "-", 
               RowBox[{"positions", "[", 
                RowBox[{"[", "baseposition", "]"}], "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"lambdalist", "[", 
                RowBox[{"[", 
                 RowBox[{"baseposition", "+", "1"}], "]"}], "]"}], "-", 
               "baselambda"}], ")"}]}], "*", 
            RowBox[{"(", 
             RowBox[{"lambda", "-", "baselambda"}], ")"}]}]}], ",", 
          RowBox[{"positions", "[", 
           RowBox[{"[", 
            RowBox[{"-", "1"}], "]"}], "]"}]}], "]"}]}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"distanceChooseLambda", "[", 
     RowBox[{"ans_", ",", "no1_", ",", "no2_", ",", "lambdalist_"}], "]"}], ":=", 
