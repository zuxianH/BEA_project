                 RowBox[{"step", "//", "N"}], ",", 
                 RowBox[{"\[CapitalLambda]vals", "//", "N"}]}], "}"}], "]"}], 
              ";", 
              RowBox[{"Break", "[", "]"}]}], ",", "\[IndentingNewLine]", 
