Cell[CellGroupData[{

Cell["Run a list of yd and it will output a file ", "Subsection",
 CellChangeTimes->{{3.9509100287869053`*^9, 3.950910040876992*^9}, {
  3.950910296365692*^9, 
  3.9509103007163553`*^9}},ExpressionUUID->"0977a93c-2b47-41e2-855e-\
83bb25ec0b14"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ydlist", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"18", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"17", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"10", ",", "7", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"10", ",", "6", ",", "4"}], "}"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{"Do", "[", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"Total", "[", 
      RowBox[{"ydlist", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "]"}]}], ";", "\n", 
    RowBox[{"rigs", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"ModestoRiggedConfig", "[", 
        RowBox[{"L", ",", "#"}], "]"}], "&"}], "/@", 
      RowBox[{"ModesConfig", "[", 
       RowBox[{"ydlist", "[", 
        RowBox[{"[", "k", "]"}], "]"}], "]"}]}]}], ";", "\n", 
    RowBox[{"stringsolver", "=", 
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"IterativeBAEsolver", "[", 
        RowBox[{"L", ",", "mode", ",", "0.005"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"mode", ",", 
         RowBox[{"ModesConfig", "[", 
          RowBox[{"ydlist", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}], ";", 
    "\n", 
    RowBox[{"iterativLazysolver", "=", 
     RowBox[{"newlazysolver", "[", 
      RowBox[{"ydlist", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "]"}]}], ";", " ", "\n", "\n", 
    RowBox[{"lazyroots", "=", 
     RowBox[{"Replace", "[", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{"Flatten", ",", 
         RowBox[{
          RowBox[{"iterativLazysolver", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "//", "N"}], ",", 
         RowBox[{"{", "3", "}"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"{", "x_List", "}"}], ":>", "x"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}]}], ";", "\n", 
    RowBox[{"stringroots", "=", 
     RowBox[{
      RowBox[{"toBetheroots", "/@", "stringsolver"}], "//", "N"}]}], ";", 
    "\n", "\n", 
    RowBox[{"filename", "=", 
     RowBox[{"\"\<yd_\>\"", "<>", 
      RowBox[{"StringRiffle", "[", 
       RowBox[{
        RowBox[{"ToString", "/@", 
         RowBox[{"ydlist", "[", 
          RowBox[{"[", "k", "]"}], "]"}]}], ",", "\"\<_\>\""}], "]"}], "<>", 
      "\"\<.csv\>\""}]}], ";", "\n", "\n", "\n", 
    RowBox[{"Export", "[", 
     RowBox[{"filename", ",", 
      RowBox[{"{", 
       RowBox[{"lazyroots", ",", "stringroots"}], "}"}]}], "]"}]}], "\n", 
   "\n", ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", 
     RowBox[{"Length", "[", "ydlist", "]"}]}], "}"}]}], "\n", "]"}]}], "Input",\

 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"d148a6d4-d483-4f5d-9ee8-889bdc3e4859"]
}, Closed]],

